package Zafu/Control/IterState

from Bosatsu/Collection/Array import (
  Array,
  size_Array,
  get_Array,
)
from Bosatsu/Num/Int64 import (
  Int64,
  add_Int64,
  int64_to_Int,
  int_low_bits_to_Int64 as i64,
  sub_Int64,
)

export (
  IterState(),
  done,
  continue,
  value,
  foldl_List,
  foldr_List,
  foldl_Array,
  foldr_Array,
  map_continue,
  map_done,
)

exposes Bosatsu/Collection/Array
enum IterState[cont: +*, done: +*]:
  Continue(cont: cont)
  Done(done: done)

def done(value: d) -> IterState[c, d]:
  Done(value)

def continue(value: c) -> IterState[c, d]:
  Continue(value)

def value(iter: IterState[a, a]) -> a:
  Done(result) | Continue(result) = iter
  result

def foldl_List(items: List[a], init: b, fn: (b, a) -> IterState[b, b]) -> IterState[b, b]:
  def go(rem: List[a], acc: b) -> IterState[b, b]:
    loop rem:
      case []:
        Continue(acc)
      case [head, *tail]:
        match fn(acc, head):
          case Done(done_value):
            Done(done_value)
          case Continue(next_acc):
            go(tail, next_acc)
  go(items, init)

def foldr_List(items: List[a], init: b, fn: (a, b) -> IterState[b, b]) -> IterState[b, b]:
  foldl_List(items.reverse(), init, (acc, item) -> fn(item, acc))

def foldl_Array(items: Array[a], init: b, fn: (b, a) -> IterState[b, b]) -> IterState[b, b]:
  cnt = size_Array(items)
  def go(rem: Int, idx: Int64, acc: b) -> IterState[b, b]:
    loop rem:
      case _ if cmp_Int(rem, 0) matches LT | EQ:
        Continue(acc)
      case _:
        match get_Array(items, idx):
          case Some(item):
            match fn(acc, item):
              case Done(done_value):
                Done(done_value)
              case Continue(next_acc):
                go(rem.sub(1), add_Int64(idx, i64(1)), next_acc)
          case None:
            Continue(acc)
  go(int64_to_Int(cnt), i64(0), init)

def foldr_Array(items: Array[a], init: b, fn: (a, b) -> IterState[b, b]) -> IterState[b, b]:
  cnt = size_Array(items)
  def go(rem: Int, idx: Int64, acc: b) -> IterState[b, b]:
    loop rem:
      case _ if cmp_Int(rem, 0) matches LT | EQ:
        Continue(acc)
      case _:
        next_idx = sub_Int64(idx, i64(1))
        match get_Array(items, next_idx):
          case Some(item):
            match fn(item, acc):
              case Done(done_value):
                Done(done_value)
              case Continue(next_acc):
                go(rem.sub(1), next_idx, next_acc)
          case None:
            Continue(acc)
  go(int64_to_Int(cnt), cnt, init)

def map_continue(state: IterState[c, d], fn: c -> e) -> IterState[e, d]:
  match state:
    case Continue(cont_value):
      Continue(fn(cont_value))
    case Done(done_value):
      Done(done_value)

def map_done(state: IterState[c, d], fn: d -> e) -> IterState[c, e]:
  match state:
    case Continue(cont_value):
      Continue(cont_value)
    case Done(done_value):
      Done(fn(done_value))
