export (
  PartialResult(),
  is_total_err,
  is_partial_err,
  is_total_ok,
  has_err,
  has_ok,
  err,
  ok,
  to_Option,
  map,
  map_err,
  and_then,
  flat_map,
  or_else,
  fold,
  unwrap_or,
  unwrap_or_else,
  unwrap,
  from_Option,
  from_Result,
  to_Result_fail_fast,
  combine_product,
