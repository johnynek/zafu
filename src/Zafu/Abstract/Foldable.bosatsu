  IterState,
  Done,
  Continue,
  done,
  continue,
  value,
  foldl_List as foldl_state_List,
  foldr_List as foldr_state_List,
)

export (
  Foldable,
  foldable_from_foldl_iter,
  foldable_from_foldr_iter,
  foldable_from_fold_iters,
  foldable_from_folds,
