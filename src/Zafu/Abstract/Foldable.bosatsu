struct Foldable[f: * -> *](
  foldl_fn: forall a, b. (f[a], b, (b, a) -> b) -> b,
  foldr_fn: forall a, b. (f[a], b, (a, b) -> b) -> b,
  fold_map_fn: forall a, b. (f[a], Monoid[b], a -> b) -> b,
  foldl_iter_fn: forall a, b. (f[a], b, (b, a) -> IterState[b, b]) -> IterState[b, b],
  foldr_iter_fn: forall a, b. (f[a], b, (a, b) -> IterState[b, b]) -> IterState[b, b],
  is_empty_fn: forall a. f[a] -> Bool,
  size_fn: forall a. f[a] -> Int,
  to_List_fn: forall a. f[a] -> List[a],
)

def not_Bool(value: Bool) -> Bool:
  if value:
    False
  else:
    True

def eq_Bool(left: Bool, right: Bool) -> Bool:
  if left:
    right
  else:
    not_Bool(right)

reverse_List = reverse

def foldr_List(items: List[a], init: b, fn: (a, b) -> b) -> b:
  reverse_List(items).foldl_List(init, (acc, item) -> fn(item, acc))

def size_List(items: List[a]) -> Int:
  items.foldl_List(0, (acc, _) -> acc.add(1))

def map_Option(value: Option[a], fn: a -> b) -> Option[b]:
  match value:
    case Some(item):
      Some(fn(item))
    case None:
      None

def eq_Option(eq_item: Eq[a], left: Option[a], right: Option[a]) -> Bool:
  match (left, right):
    case (None, None):
      True
    case (Some(left_item), Some(right_item)):
      eq_Eq(eq_item, left_item, right_item)
    case _:
      False

def eq_List(eq_item: Eq[a], left: List[a], right: List[a]) -> Bool:
  def go(left: List[a], right: List[a]) -> Bool:
    loop (left, right):
      case ([], []):
        True
      case ([left_h, *left_t], [right_h, *right_t]):
        if eq_Eq(eq_item, left_h, right_h):
          go(left_t, right_t)
        else:
          False
      case _:
        False
  go(left, right)

def foldable_specialized[f: * -> *](
  foldl_fn: forall a, b. (f[a], b, (b, a) -> b) -> b,
  foldr_fn: forall a, b. (f[a], b, (a, b) -> b) -> b,
  fold_map_fn: forall a, b. (f[a], Monoid[b], a -> b) -> b,
  foldl_iter_fn: forall a, b. (f[a], b, (b, a) -> IterState[b, b]) -> IterState[b, b],
  foldr_iter_fn: forall a, b. (f[a], b, (a, b) -> IterState[b, b]) -> IterState[b, b],
  is_empty_fn: forall a. f[a] -> Bool,
  size_fn: forall a. f[a] -> Int,
  to_List_fn: forall a. f[a] -> List[a],
) -> Foldable[f]:
  Foldable(foldl_fn, foldr_fn, fold_map_fn, foldl_iter_fn, foldr_iter_fn, is_empty_fn, size_fn, to_List_fn)

def foldable_from_foldl_iter[f: * -> *](
  foldl_iter_fn: forall a, b. (f[a], b, (b, a) -> IterState[b, b]) -> IterState[b, b]
) -> Foldable[f]:
  to_List_fn = (fa) -> reverse_List(value(foldl_iter_fn(fa, [], (acc, item) -> continue([item, *acc]))))
  foldable_specialized(
    (fa, init, fn) -> value(foldl_iter_fn(fa, init, (acc, item) -> continue(fn(acc, item)))),
    (fa, init, fn) -> foldr_List(to_List_fn(fa), init, fn),
    (fa, monoid, fn) -> value(
      foldl_iter_fn(fa, monoid.empty(), (acc, item) -> continue(monoid.combine(acc, fn(item))))
    ),
    foldl_iter_fn,
    (fa, init, fn) -> foldr_state_List(to_List_fn(fa), init, fn),
    (fa) -> value(foldl_iter_fn(fa, True, (_, _) -> done(False))),
    (fa) -> value(foldl_iter_fn(fa, 0, (acc, _) -> continue(acc.add(1)))),
    to_List_fn,
  )

def foldable_from_foldr_iter[f: * -> *](
  foldr_iter_fn: forall a, b. (f[a], b, (a, b) -> IterState[b, b]) -> IterState[b, b]
) -> Foldable[f]:
  to_List_fn = (fa) -> value(foldr_iter_fn(fa, [], (item, acc) -> continue([item, *acc])))
  foldable_specialized(
    (fa, init, fn) -> to_List_fn(fa).foldl_List(init, fn),
    (fa, init, fn) -> value(foldr_iter_fn(fa, init, (item, acc) -> continue(fn(item, acc)))),
    (fa, monoid, fn) -> value(
      foldr_iter_fn(fa, monoid.empty(), (item, acc) -> continue(monoid.combine(fn(item), acc)))
    ),
    (fa, init, fn) -> foldl_state_List(to_List_fn(fa), init, fn),
    foldr_iter_fn,
    (fa) -> value(foldr_iter_fn(fa, True, (_, _) -> done(False))),
    (fa) -> value(foldr_iter_fn(fa, 0, (_, acc) -> continue(acc.add(1)))),
    to_List_fn,
  )

def foldable_from_fold_iters[f: * -> *](
  foldl_iter_fn: forall a, b. (f[a], b, (b, a) -> IterState[b, b]) -> IterState[b, b],
  foldr_iter_fn: forall a, b. (f[a], b, (a, b) -> IterState[b, b]) -> IterState[b, b],
) -> Foldable[f]:
  to_List_fn = (fa) -> value(foldr_iter_fn(fa, [], (item, acc) -> continue([item, *acc])))
  foldable_specialized(
    (fa, init, fn) -> value(foldl_iter_fn(fa, init, (acc, item) -> continue(fn(acc, item)))),
    (fa, init, fn) -> value(foldr_iter_fn(fa, init, (item, acc) -> continue(fn(item, acc)))),
    (fa, monoid, fn) -> value(
      foldl_iter_fn(fa, monoid.empty(), (acc, item) -> continue(monoid.combine(acc, fn(item))))
    ),
    foldl_iter_fn,
    foldr_iter_fn,
    (fa) -> value(foldl_iter_fn(fa, True, (_, _) -> done(False))),
    (fa) -> value(foldl_iter_fn(fa, 0, (acc, _) -> continue(acc.add(1)))),
    to_List_fn,
  )

def foldable_from_folds[f: * -> *](
  foldl_fn: forall a, b. (f[a], b, (b, a) -> b) -> b,
  foldr_fn: forall a, b. (f[a], b, (a, b) -> b) -> b,
) -> Foldable[f]:
  # Strict folds still traverse the full structure; keep Done sticky so
  # iterative helper semantics remain correct even without early-stop speedups.
  foldable_specialized(
    foldl_fn,
    foldr_fn,
    (fa, monoid, fn) -> foldl_fn(fa, monoid.empty(), (acc, item) -> monoid.combine(acc, fn(item))),
    (fa, init, fn) -> foldl_fn(fa, Continue(init), (state, item) -> (
      match state:
        case Done(done_value):
          Done(done_value)
        case Continue(acc):
          fn(acc, item)
    )),
    (fa, init, fn) -> foldr_fn(fa, Continue(init), (item, state) -> (
      match state:
        case Done(done_value):
          Done(done_value)
        case Continue(acc):
          fn(item, acc)
    )),
    (fa) -> foldl_fn(fa, True, (_, _) -> False),
    (fa) -> foldl_fn(fa, 0, (acc, _) -> acc.add(1)),
    (fa) -> foldr_fn(fa, [], (item, acc) -> [item, *acc]),
  )

def foldl[f: * -> *](fa: f[a], inst: Foldable[f], init: b, fn: (b, a) -> b) -> b:
  Foldable { foldl_fn, ... } = inst
  foldl_fn(fa, init, fn)

def foldr[f: * -> *](fa: f[a], inst: Foldable[f], init: b, fn: (a, b) -> b) -> b:
  Foldable { foldr_fn, ... } = inst
  foldr_fn(fa, init, fn)

def foldl_iter[f: * -> *](fa: f[a], inst: Foldable[f], init: b, fn: (b, a) -> IterState[b, b]) -> b:
  Foldable { foldl_iter_fn, ... } = inst
  value(foldl_iter_fn(fa, init, fn))

def foldr_iter[f: * -> *](fa: f[a], inst: Foldable[f], init: b, fn: (a, b) -> IterState[b, b]) -> b:
  Foldable { foldr_iter_fn, ... } = inst
  value(foldr_iter_fn(fa, init, fn))

def is_empty[f: * -> *](fa: f[a], inst: Foldable[f]) -> Bool:
  Foldable { is_empty_fn, ... } = inst
  is_empty_fn(fa)

def non_empty[f: * -> *](fa: f[a], inst: Foldable[f]) -> Bool:
  not_Bool(fa.is_empty(inst))

def size[f: * -> *](fa: f[a], inst: Foldable[f]) -> Int:
  Foldable { size_fn, ... } = inst
  size_fn(fa)

def to_List[f: * -> *](fa: f[a], inst: Foldable[f]) -> List[a]:
  Foldable { to_List_fn, ... } = inst
  to_List_fn(fa)

def fold_map[f: * -> *](fa: f[a], inst: Foldable[f], monoid: Monoid[b], fn: a -> b) -> b:
  Foldable { fold_map_fn, ... } = inst
  fold_map_fn(fa, monoid, fn)

def traverse_void[f: * -> *, g: * -> *, a, b](
  fa: f[a],
  inst: Foldable[f],
  app: Applicative[g],
  fn: a -> g[b],
) -> g[Unit]:
  monoid_unit = monoid_from_combine(
    app.pure(()),
    (left, right) -> app.product_left(left, right),
  )
  fa.fold_map(inst, monoid_unit, item -> fn(item).void(app))

def sequence_void[f: * -> *, g: * -> *, a](fga: f[g[a]], inst: Foldable[f], app: Applicative[g]) -> g[Unit]:
  fga.traverse_void(inst, app, ga -> ga)

def combine_all[f: * -> *](fa: f[a], inst: Foldable[f], monoid: Monoid[a]) -> a:
  fa.fold_map(inst, monoid, item -> item)

def fold[f: * -> *](fa: f[a], inst: Foldable[f], monoid: Monoid[a]) -> a:
  fa.combine_all(inst, monoid)

def combine_all_option[f: * -> *](fa: f[a], inst: Foldable[f], semigroup: Semigroup[a]) -> Option[a]:
  fa.foldl(inst, None, (state, item) -> (
    match state:
      case None:
        Some(item)
      case Some(acc):
        Some(combine_sg(semigroup, acc, item))
  ))

def fold_map_option[f: * -> *](fa: f[a], inst: Foldable[f], semigroup: Semigroup[b], fn: a -> b) -> Option[b]:
  fa.foldl(inst, None, (state, item) -> (
    mapped = fn(item)
    match state:
      case None:
        Some(mapped)
      case Some(acc):
        Some(combine_sg(semigroup, acc, mapped))
  ))

def reduce_left_to_option[f: * -> *](
  fa: f[a],
  inst: Foldable[f],
  first: a -> b,
  combine: (b, a) -> b,
) -> Option[b]:
  fa.foldl(inst, None, (state, item) -> (
    match state:
      case None:
        Some(first(item))
      case Some(acc):
        Some(combine(acc, item))
  ))

def reduce_right_to_option[f: * -> *](
  fa: f[a],
  inst: Foldable[f],
  first: a -> b,
  combine: (a, b) -> b,
) -> Option[b]:
  fa.foldr(inst, None, (item, state) -> (
    match state:
      case None:
        Some(first(item))
      case Some(acc):
        Some(combine(item, acc))
  ))

def reduce_left_option[f: * -> *](fa: f[a], inst: Foldable[f], combine: (a, a) -> a) -> Option[a]:
  fa.reduce_left_to_option(inst, item -> item, combine)

def reduce_right_option[f: * -> *](fa: f[a], inst: Foldable[f], combine: (a, a) -> a) -> Option[a]:
  fa.reduce_right_to_option(inst, item -> item, combine)

def find[f: * -> *](fa: f[a], inst: Foldable[f], pred: a -> Bool) -> Option[a]:
  fa.foldl_iter(inst, None, (_, item) -> (
    if pred(item):
      done(Some(item))
    else:
      continue(None)
  ))

def exists[f: * -> *](fa: f[a], inst: Foldable[f], pred: a -> Bool) -> Bool:
  fa.foldl_iter(inst, False, (_, item) -> (
    if pred(item):
      done(True)
    else:
      continue(False)
  ))

def for_all[f: * -> *](fa: f[a], inst: Foldable[f], pred: a -> Bool) -> Bool:
  fa.foldl_iter(inst, True, (_, item) -> (
    if pred(item):
      continue(True)
    else:
      done(False)
  ))

def any[f: * -> *](fa: f[Bool], inst: Foldable[f]) -> Bool:
  fa.exists(inst, item -> item)

def all[f: * -> *](fa: f[Bool], inst: Foldable[f]) -> Bool:
  fa.for_all(inst, item -> item)

def contains[f: * -> *](fa: f[a], inst: Foldable[f], eq_inst: Eq[a], target: a) -> Bool:
  fa.exists(inst, item -> eq_Eq(eq_inst, item, target))

def count[f: * -> *](fa: f[a], inst: Foldable[f], pred: a -> Bool) -> Int:
  fa.foldl(inst, 0, (acc, item) -> acc.add(1) if pred(item) else acc)

def get[f: * -> *](fa: f[a], inst: Foldable[f], idx: Int) -> Option[a]:
  if cmp_Int(idx, 0) matches LT:
    None
  else:
    state = fa.foldl_iter(inst, (0, None), (state, item) -> (
      (next_idx, _) = state
      if next_idx.eq_Int(idx):
        done((next_idx, Some(item)))
      else:
        continue((next_idx.add(1), None))
    ))
    (_, result) = state
    result

def collect_first_some[f: * -> *](fa: f[a], inst: Foldable[f], fn: a -> Option[b]) -> Option[b]:
  fa.foldl_iter(inst, None, (_, item) -> (
    match fn(item):
      case Some(value):
        done(Some(value))
      case None:
        continue(None)
  ))

def collect_fold_some[f: * -> *](fa: f[a], inst: Foldable[f], monoid: Monoid[b], fn: a -> Option[b]) -> b:
  fa.foldl(inst, monoid.empty(), (acc, item) -> (
    match fn(item):
      case Some(value):
        monoid.combine(acc, value)
      case None:
        acc
  ))

def minimum_option[f: * -> *](fa: f[a], inst: Foldable[f], ord_inst: Ord[a]) -> Option[a]:
  fa.reduce_left_option(inst, (left, right) -> (
    match cmp_Ord(ord_inst, left, right):
      case GT:
        right
      case LT | EQ:
        left
  ))

def maximum_option[f: * -> *](fa: f[a], inst: Foldable[f], ord_inst: Ord[a]) -> Option[a]:
  fa.reduce_left_option(inst, (left, right) -> (
    match cmp_Ord(ord_inst, left, right):
      case LT:
        right
      case GT | EQ:
        left
  ))

def minimum_by_option[f: * -> *](fa: f[a], inst: Foldable[f], ord_b: Ord[b], fn: a -> b) -> Option[a]:
  state = fa.reduce_left_to_option(
    inst,
    (item) -> (item, fn(item)),
    (acc, item) -> (
      (best_item, best_key) = acc
      key = fn(item)
      match cmp_Ord(ord_b, key, best_key):
        case LT:
          (item, key)
        case EQ | GT:
          (best_item, best_key)
    ),
  )
  map_Option(state, (((best_item, _)) -> best_item))

def maximum_by_option[f: * -> *](fa: f[a], inst: Foldable[f], ord_b: Ord[b], fn: a -> b) -> Option[a]:
  state = fa.reduce_left_to_option(
    inst,
    (item) -> (item, fn(item)),
    (acc, item) -> (
      (best_item, best_key) = acc
      key = fn(item)
      match cmp_Ord(ord_b, key, best_key):
        case GT:
          (item, key)
        case LT | EQ:
          (best_item, best_key)
    ),
  )
  map_Option(state, (((best_item, _)) -> best_item))

def minimum_by_list[f: * -> *](fa: f[a], inst: Foldable[f], ord_b: Ord[b], fn: a -> b) -> List[a]:
  state = fa.foldl(inst, None, (state, item) -> (
    key = fn(item)
    match state:
      case None:
        Some((key, [item]))
      case Some((best_key, best_rev)):
        match cmp_Ord(ord_b, key, best_key):
          case LT:
            Some((key, [item]))
          case EQ:
            Some((best_key, [item, *best_rev]))
          case GT:
            Some((best_key, best_rev))
  ))
  match state:
    case None:
      []
    case Some((_, best_rev)):
      reverse_List(best_rev)

def maximum_by_list[f: * -> *](fa: f[a], inst: Foldable[f], ord_b: Ord[b], fn: a -> b) -> List[a]:
  state = fa.foldl(inst, None, (state, item) -> (
    key = fn(item)
    match state:
      case None:
        Some((key, [item]))
      case Some((best_key, best_rev)):
        match cmp_Ord(ord_b, key, best_key):
          case GT:
            Some((key, [item]))
          case EQ:
            Some((best_key, [item, *best_rev]))
          case LT:
            Some((best_key, best_rev))
  ))
  match state:
    case None:
      []
    case Some((_, best_rev)):
      reverse_List(best_rev)

def minimum_list[f: * -> *](fa: f[a], inst: Foldable[f], ord_inst: Ord[a]) -> List[a]:
  fa.minimum_by_list(inst, ord_inst, item -> item)

def maximum_list[f: * -> *](fa: f[a], inst: Foldable[f], ord_inst: Ord[a]) -> List[a]:
  fa.maximum_by_list(inst, ord_inst, item -> item)

def intercalate[f: * -> *](fa: f[a], inst: Foldable[f], monoid: Monoid[a], middle: a) -> a:
  (_, total) = fa.foldl(inst, (False, monoid.empty()), (state, item) -> (
    (seen_any, acc) = state
    if seen_any:
      (True, monoid.combine(monoid.combine(acc, middle), item))
    else:
      (True, monoid.combine(acc, item))
  ))
  total

def filter_to_List[f: * -> *](fa: f[a], inst: Foldable[f], pred: a -> Bool) -> List[a]:
  reverse_List(fa.foldl(inst, [], (acc, item) -> [item, *acc] if pred(item) else acc))

def take_while_to_List[f: * -> *](fa: f[a], inst: Foldable[f], pred: a -> Bool) -> List[a]:
  reverse_List(fa.foldl_iter(inst, [], (acc, item) -> (
    if pred(item):
      continue([item, *acc])
    else:
      done(acc)
  )))

def drop_while_to_List[f: * -> *](fa: f[a], inst: Foldable[f], pred: a -> Bool) -> List[a]:
  (_, kept_rev) = fa.foldl(inst, (True, []), (state, item) -> (
    (still_dropping, kept_rev) = state
    if still_dropping:
      if pred(item):
        state
      else:
        (False, [item, *kept_rev])
    else:
      (False, [item, *kept_rev])
  ))
  reverse_List(kept_rev)

def reduce_left_option_List(items: List[a], combine: (a, a) -> a) -> Option[a]:
  match items:
    case []:
      None
    case [head, *tail]:
      Some(tail.foldl_List(head, combine))

def reduce_right_option_List(items: List[a], combine: (a, a) -> a) -> Option[a]:
  match reverse_List(items):
    case []:
      None
    case [last, *init_rev]:
      Some(init_rev.foldl_List(last, (acc, item) -> combine(item, acc)))

applicative_Option: Applicative[Option] = applicative_from_pure_map_map2(
  Some,
  (value, fn) -> (
    match value:
      case Some(item):
        Some(fn(item))
      case None:
        None
  ),
  (left, right, fn) -> (
    match (left, right):
      case (Some(left_item), Some(right_item)):
        Some(fn(left_item, right_item))
      case _:
        None
  ),
)

struct Writer[a](log: List[Int], value: a)

def map_Writer(writer: Writer[a], fn: a -> b) -> Writer[b]:
  Writer(log, value) = writer
  Writer(log, fn(value))

def map2_Writer(left: Writer[a], right: Writer[b], fn: (a, b) -> c) -> Writer[c]:
  match (left, right):
    case (Writer(left_log, left_value), Writer(right_log, right_value)):
      Writer([*left_log, *right_log], fn(left_value, right_value))

applicative_Writer: Applicative[Writer] = applicative_from_pure_map_map2(
  value -> Writer([], value),
  map_Writer,
  map2_Writer,
)

def laws_Foldable[f: * -> *](inst: Foldable[f], eq_item: Eq[a], fa: f[a]) -> Test:
  list_view = fa.to_List(inst)
  left_reduced = fa.reduce_left_option(inst, (left, _) -> left)
  right_reduced = fa.reduce_right_option(inst, (left, _) -> left)
  left_model = reduce_left_option_List(list_view, (left, _) -> left)
  right_model = reduce_right_option_List(list_view, (left, _) -> left)

  size_law = Assertion(fa.size(inst).eq_Int(size_List(list_view)), "size equals to_List length")
  is_empty_law = Assertion(eq_Bool(fa.is_empty(inst), fa.size(inst).eq_Int(0)), "is_empty from size")
  non_empty_law = Assertion(eq_Bool(fa.non_empty(inst), not_Bool(fa.is_empty(inst))), "non_empty negates is_empty")
  foldl_law = Assertion(
    eq_List(eq_item, reverse_List(fa.foldl(inst, [], (acc, item) -> [item, *acc])), list_view),
    "foldl order matches to_List",
  )
  foldr_law = Assertion(
    eq_List(eq_item, fa.foldr(inst, [], (item, acc) -> [item, *acc]), list_view),
    "foldr order matches to_List",
  )
  foldl_iter_law = Assertion(
    eq_List(
      eq_item,
      fa.foldl_iter(inst, [], (acc, item) -> continue([item, *acc])),
      fa.foldl(inst, [], (acc, item) -> [item, *acc]),
    ),
    "foldl_iter Continue agrees with foldl",
  )
  foldr_iter_law = Assertion(
    eq_List(
      eq_item,
      fa.foldr_iter(inst, [], (item, acc) -> continue([item, *acc])),
      fa.foldr(inst, [], (item, acc) -> [item, *acc]),
    ),
    "foldr_iter Continue agrees with foldr",
  )
  reduce_left_law = Assertion(eq_Option(eq_item, left_reduced, left_model), "reduce_left_option list model")
  reduce_right_law = Assertion(eq_Option(eq_item, right_reduced, right_model), "reduce_right_option list model")
  TestSuite("Foldable laws", [
    size_law,
    is_empty_law,
    non_empty_law,
    foldl_law,
    foldr_law,
    foldl_iter_law,
    foldr_iter_law,
    reduce_left_law,
    reduce_right_law,
  ])

foldable_List: Foldable[List] = foldable_specialized(
  (items, init, fn) -> items.foldl_List(init, fn),
  (items, init, fn) -> foldr_List(items, init, fn),
  (items, monoid, fn) -> combine_all_monoid(monoid, items.map_List(fn)),
  foldl_state_List,
  foldr_state_List,
  (items) -> items matches [],
  size_List,
  (items) -> items,
)

tests = TestSuite("Foldable tests", [
  (
    eq_int = eq_from_fn(eq_Int)
    laws_Foldable(foldable_List, eq_int, [])
  ),
  (
    eq_int = eq_from_fn(eq_Int)
    laws_Foldable(foldable_List, eq_int, [3, 1, 2, 1])
  ),
  (
    int_monoid = monoid_from_combine(0, (left, right) -> left.add(right))
    Assertion(([1, 2, 3]).fold(foldable_List, int_monoid).eq_Int(6), "fold")
  ),
  (
    int_semigroup = semigroup_from_combine((left, right) -> left.add(right))
    Assertion(([1, 2, 3]).combine_all_option(foldable_List, int_semigroup) matches Some(6), "combine_all_option")
  ),
  (
    int_semigroup = semigroup_from_combine((left, right) -> left.add(right))
    Assertion(([]).combine_all_option(foldable_List, int_semigroup) matches None, "combine_all_option empty")
  ),
  (
    int_monoid = monoid_from_combine(0, (left, right) -> left.add(right))
    Assertion(([1, 2, 3]).fold_map(foldable_List, int_monoid, x -> x.mul(2)).eq_Int(12), "fold_map")
  ),
  (
    int_semigroup = semigroup_from_combine((left, right) -> left.add(right))
    Assertion(([1, 2, 3]).fold_map_option(foldable_List, int_semigroup, x -> x.mul(2)) matches Some(12), "fold_map_option")
  ),
  Assertion(([1, 2, 3]).reduce_left_option(foldable_List, (left, right) -> left.sub(right)) matches Some(-4), "reduce_left_option"),
  Assertion(([1, 2, 3]).reduce_right_option(foldable_List, (left, right) -> left.sub(right)) matches Some(2), "reduce_right_option"),
  Assertion(([1, 2, 3]).find(foldable_List, x -> x.eq_Int(2)) matches Some(2), "find"),
  Assertion(([1, 2, 3]).find(foldable_List, x -> x.eq_Int(7)) matches None, "find miss"),
  Assertion(([1, 2, 3]).exists(foldable_List, x -> x.eq_Int(3)), "exists"),
  Assertion(([2, 4, 6]).for_all(foldable_List, x -> mod_Int(x, 2).eq_Int(0)), "for_all"),
  Assertion(([False, True, False]).any(foldable_List), "any"),
  Assertion(([True, True]).all(foldable_List), "all"),
  (
    eq_int = eq_from_fn(eq_Int)
    Assertion(([1, 2, 3]).contains(foldable_List, eq_int, 2), "contains")
  ),
  Assertion(([1, 2, 3, 4]).count(foldable_List, x -> mod_Int(x, 2).eq_Int(0)).eq_Int(2), "count"),
  Assertion(([1, 2, 3]).get(foldable_List, 1) matches Some(2), "get"),
  Assertion(([1, 2, 3]).get(foldable_List, 10) matches None, "get out of bounds"),
  Assertion(([1, 2, 3]).collect_first_some(foldable_List, x -> Some(x) if x.eq_Int(2) else None) matches Some(2), "collect_first_some"),
  (
    int_monoid = monoid_from_combine(0, (left, right) -> left.add(right))
    Assertion(
      ([1, 2, 3, 4]).collect_fold_some(foldable_List, int_monoid, x -> Some(x) if mod_Int(x, 2).eq_Int(0) else None).eq_Int(6),
      "collect_fold_some",
    )
  ),
  (
    ord_int = ord_from_cmp(cmp_Int)
    Assertion(([3, 1, 2]).minimum_option(foldable_List, ord_int) matches Some(1), "minimum_option")
  ),
  (
    ord_int = ord_from_cmp(cmp_Int)
    Assertion(([3, 1, 2]).maximum_option(foldable_List, ord_int) matches Some(3), "maximum_option")
  ),
  (
    ord_int = ord_from_cmp(cmp_Int)
    Assertion(([3, 1, 2, 1]).minimum_list(foldable_List, ord_int) matches [1, 1], "minimum_list")
  ),
  (
    ord_int = ord_from_cmp(cmp_Int)
    Assertion(([3, 1, 3, 2]).maximum_list(foldable_List, ord_int) matches [3, 3], "maximum_list")
  ),
  (
    ord_int = ord_from_cmp(cmp_Int)
    Assertion(([-2, 3, -1]).minimum_by_option(foldable_List, ord_int, x -> x.mul(x)) matches Some(-1), "minimum_by_option")
  ),
  (
    ord_int = ord_from_cmp(cmp_Int)
    Assertion(([-2, 3, -1]).maximum_by_option(foldable_List, ord_int, x -> x.mul(x)) matches Some(3), "maximum_by_option")
  ),
  (
    string_monoid = monoid_from_combine("", (left, right) -> concat_String([left, right]))
    Assertion((["a", "b", "c"]).intercalate(foldable_List, string_monoid, ",") matches "a,b,c", "intercalate")
  ),
  Assertion(([1, 2, 3, 4]).filter_to_List(foldable_List, x -> mod_Int(x, 2).eq_Int(0)) matches [2, 4], "filter_to_List"),
  Assertion(([2, 4, 6, 7, 8]).take_while_to_List(foldable_List, x -> mod_Int(x, 2).eq_Int(0)) matches [2, 4, 6], "take_while_to_List"),
  Assertion(([2, 4, 6, 7, 8]).drop_while_to_List(foldable_List, x -> mod_Int(x, 2).eq_Int(0)) matches [7, 8], "drop_while_to_List"),
  Assertion(
    ([1, 2, 3]).traverse_void(foldable_List, applicative_Option, value -> Some(value.add(1))) matches Some(()),
    "traverse_void Option success",
  ),
  Assertion(
    ([Some(1), None, Some(3)]).sequence_void(foldable_List, applicative_Option) matches None,
    "sequence_void Option failure",
  ),
  (
    match ([1, 2, 3]).traverse_void(foldable_List, applicative_Writer, value -> Writer([value], value)):
      case Writer(log, ()):
        Assertion(log matches [1, 2, 3], "traverse_void preserves Foldable order")
  ),
  (
    from_foldl = foldable_from_foldl_iter((items, init, fn) -> foldl_state_List(items, init, fn))
    Assertion(([1, 2, 3]).to_List(from_foldl) matches [1, 2, 3], "foldable_from_foldl_iter")
  ),
  (
    from_foldr = foldable_from_foldr_iter((items, init, fn) -> foldr_state_List(items, init, fn))
    Assertion(([1, 2, 3]).size(from_foldr).eq_Int(3), "foldable_from_foldr_iter")
  ),
  (
    from_folds = foldable_from_folds(
      (items, init, fn) -> items.foldl_List(init, fn),
      (items, init, fn) -> foldr_List(items, init, fn),
    )
    Assertion(([1, 2, 3]).get(from_folds, 1) matches Some(2), "foldable_from_folds iter wrapper")
  ),
])
