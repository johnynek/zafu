  sequence_void,
  fold,
  combine_all,
  combine_all_option,
  fold_map,
  fold_map_option,
  reduce_left_to_option,
  reduce_right_to_option,
  reduce_left_option,
  reduce_right_option,
  find,
  exists,
  for_all,
  any,
  all,
  contains,
  count,
  get,
  collect_first_some,
  collect_fold_some,
