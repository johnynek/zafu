  ),
  Assertion(
    combine_map_all_Monoid(monoid_List, [1, 2, 3], value -> [value, value]) matches [1, 1, 2, 2, 3, 3],
    "monoid_List combine_map_all",
  ),
  (
    tuple2_monoid = monoid_Tuple2(monoid_Int_add, monoid_Bool_or)
    Assertion(
      combine_Monoid(tuple2_monoid, Tuple2(1, False), Tuple2(2, True)) matches Tuple2(3, True),
