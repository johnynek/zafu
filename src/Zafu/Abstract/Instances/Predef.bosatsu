def eq_Dict(eq_key: Eq[k], eq_value: Eq[v]) -> Eq[Dict[k, v]]:
  pair_eq = eq_Tuple2(eq_key, eq_value)
  eq_from_fn((left, right) -> eq_list(pair_eq, items(left), items(right)))

def ord_Dict(ord_key: Ord[k], ord_value: Ord[v]) -> Ord[Dict[k, v]]:
  pair_ord = ord_Tuple2(ord_key, ord_value)
  ord_from_cmp((left, right) -> cmp_list(pair_ord, items(left), items(right)))

def hash_Dict(hash_key: Hash[k], hash_value: Hash[v]) -> Hash[Dict[k, v]]:
  pair_hash = hash_Tuple2(hash_key, hash_value)
  list_hash = hash_List(pair_hash)
  eq_key = hash_to_Eq(hash_key)
  eq_value = hash_to_Eq(hash_value)
  # Keep dict hashing aligned with eq_Dict by hashing ordered items(dict).
  hash_specialized(
    (value) -> mix_61(hash_Hash(list_hash, items(value)), hash_tag_dict),
    eq_Dict(eq_key, eq_value),
  )

tests = TestSuite("Predef Eq/Ord/Hash instances", [
  Assertion(eq_Eq(eq_Int, 1, 1), "eq_Int"),
  Assertion(cmp_Ord(ord_Int, 1, 2) matches LT, "ord_Int"),
  Assertion(eq_Eq(eq_Int, hash_Hash(hash_Int, -1), normalize_61(-1)), "hash_Int"),
  (
    opt_eq = eq_Option(eq_Int)
    Assertion(eq_Eq(opt_eq, Some(1), Some(1)), "eq_Option")
  ),
  (
    opt_hash = hash_Option(hash_Int)
    Assertion(
      if eq_Eq(eq_Int, hash_Hash(opt_hash, None), hash_Hash(opt_hash, Some(0))):
        False
      else:
        True,
      "hash_Option tags constructors",
    )
  ),
  (
    pair_eq = eq_Tuple2(eq_Int, eq_String)
    Assertion(eq_Eq(pair_eq, Tuple2(1, "a"), Tuple2(1, "a")), "eq_Tuple2")
  ),
  (
    pair_hash = hash_Tuple2(hash_Int, hash_Int)
    Assertion(
      if eq_Eq(eq_Int, hash_Hash(pair_hash, Tuple2(1, 2)), hash_Hash(pair_hash, Tuple2(2, 1))):
        False
      else:
        True,
      "hash_Tuple2 order-sensitive",
    )
  ),
  (
    list_ord = ord_List(ord_Int)
    Assertion(cmp_Ord(list_ord, [1, 2], [1, 3]) matches LT, "ord_List")
  ),
  (
    list_hash = hash_List(hash_Int)
    Assertion(
      if eq_Eq(eq_Int, hash_Hash(list_hash, [1, 2]), hash_Hash(list_hash, [2, 1])):
        False
      else:
        True,
      "hash_List order-sensitive",
    )
  ),
  (
    tuple3_eq = eq_Tuple3(eq_Int, eq_Int, eq_Int)
    Assertion(
      if eq_Eq(tuple3_eq, Tuple3(1, 2, 3), Tuple3(1, 2, 4)):
        False
      else:
        True,
      "eq_Tuple3 compares fields",
    )
  ),
  (
    tuple3_ord = ord_Tuple3(ord_Int, ord_Int, ord_Int)
    Assertion(
      cmp_Ord(tuple3_ord, Tuple3(1, 2, 3), Tuple3(1, 2, 4)) matches LT,
      "ord_Tuple3 lexicographic",
    )
  ),
  (
    nan1 = int_bits_to_Float64(9221120237041090561)
    nan2 = int_bits_to_Float64(9221120237041090562)
    Assertion(
      eq_Eq(eq_Int, hash_Hash(hash_Float64, nan1), hash_Hash(hash_Float64, nan2)),
      "hash_Float64 canonicalizes NaN payloads",
    )
  ),
  (
    neg_zero = int_bits_to_Float64(9223372036854775808)
    pos_zero = int_bits_to_Float64(0)
    Assertion(
      eq_Eq(eq_Int, hash_Hash(hash_Float64, neg_zero), hash_Hash(hash_Float64, pos_zero)),
      "hash_Float64 treats signed zero equally",
    )
  ),
])
