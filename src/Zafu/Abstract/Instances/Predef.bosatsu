def and_Bool(left: Bool, right: Bool) -> Bool:
  if left:
    right
  else:
    False

def or_Bool(left: Bool, right: Bool) -> Bool:
  if left:
    True
  else:
    right

def cmp_then(first: Comparison, next: () -> Comparison) -> Comparison:
  if first matches EQ:
    next()
  else:
    first

def cmp_Bool(left: Bool, right: Bool) -> Comparison:
  match (left, right):
    case (False, True):
      LT
    case (True, False):
      GT
    case _:
      EQ

def rank_Comparison(value: Comparison) -> Int:
  match value:
    case LT:
      0
    case EQ:
      1
    case GT:
      2

def cmp_Comparison(left: Comparison, right: Comparison) -> Comparison:
  cmp_Int(rank_Comparison(left), rank_Comparison(right))

hash_tag_unit: Int = 1009
hash_tag_bool_false: Int = 1013
hash_tag_bool_true: Int = 1019
hash_seed_comparison: Int = 1031
hash_tag_comparison: Int = 1033
hash_float64_nan: Int = 1039
hash_float64_zero: Int = 1049
hash_seed_string: Int = 1061
hash_tag_string: Int = 1063
hash_seed_option_none: Int = 1091
hash_tag_option_none: Int = 1093
hash_seed_option_some: Int = 1097
hash_tag_option_some: Int = 1103
hash_seed_list: Int = 1123
hash_tag_list: Int = 1129
hash_tuple_seed_base: Int = 1201
hash_tuple_tag_base: Int = 1301
hash_tag_dict: Int = 1409

def hash_list(hash_item: Hash[a], seed: Int, tag: Int, value: List[a]) -> Int:
  def go(rem: List[a], acc: Int, size: Int) -> Int:
    loop rem:
      case []:
        finish_61(acc, size, tag)
      case [head, *tail]:
        go(tail, mix_61(acc, hash_Hash(hash_item, head)), size.add(1))
  go(value, seed, 0)

def hash_string_value(value: String) -> Int:
  # Eq/String compares UTF-8 byte sequences, so hashing bytes preserves coherence.
  bytes = utf8_bytes_from_String(value)
  mixed = foldl_Bytes(bytes, hash_seed_string, (acc, byte) -> mix_61(acc, normalize_61(byte)))
  finish_61(mixed, size_Bytes(bytes), hash_tag_string)

ord_Unit: Ord[Unit] = ord_from_cmp((_, _) -> EQ)
eq_Unit: Eq[Unit] = ord_to_eq(ord_Unit)
hash_Unit: Hash[Unit] = hash_specialized(_ -> hash_tag_unit, eq_Unit)

ord_Bool: Ord[Bool] = ord_from_cmp(cmp_Bool)
eq_Bool: Eq[Bool] = ord_to_eq(ord_Bool)
hash_Bool: Hash[Bool] = hash_specialized(
  (value) -> (
    if value:
      hash_tag_bool_true
    else:
      hash_tag_bool_false
  ),
  eq_Bool,
)

ord_Char: Ord[Char] = ord_from_cmp(cmp_Char)
eq_Char: Eq[Char] = ord_to_eq(ord_Char)
hash_Char: Hash[Char] = hash_from_fn(char_to_Int, eq_Char)

ord_Comparison: Ord[Comparison] = ord_from_cmp(cmp_Comparison)
eq_Comparison: Eq[Comparison] = ord_to_eq(ord_Comparison)
hash_Comparison: Hash[Comparison] = hash_specialized(
  value -> finish_61(hash_seed_comparison, rank_Comparison(value), hash_tag_comparison),
  eq_Comparison,
)

ord_Int: Ord[Int] = ord_from_cmp(cmp_Int)
eq_Int: Eq[Int] = ord_to_eq(ord_Int)
hash_Int: Hash[Int] = hash_from_fn(value -> value, eq_Int)

ord_Float64: Ord[Float64] = ord_from_cmp(cmp_Float64)
eq_Float64: Eq[Float64] = ord_to_eq(ord_Float64)
hash_Float64: Hash[Float64] = hash_specialized(
  (value) -> (
    # cmp_Float64 treats all NaNs and both signed zeros as equal.
    if is_nan(value):
      hash_float64_nan
    else:
      if cmp_Float64(value, 0.0) matches EQ:
        hash_float64_zero
      else:
        normalize_61(float64_bits_to_Int(value))
  ),
  eq_Float64,
)

ord_String: Ord[String] = ord_from_cmp(cmp_String)
eq_String: Eq[String] = ord_to_eq(ord_String)
hash_String: Hash[String] = hash_specialized(hash_string_value, eq_String)

semigroup_Unit: Semigroup[Unit] = semigroup_specialized(
  (_, _) -> (),
  (_, _) -> (),
  (head, _, fn) -> fn(head),
)
monoid_Unit: Monoid[Unit] = monoid_from_semigroup((), semigroup_Unit)

def combine_n_positive_or_self(semigroup_item: Semigroup[a], value: a, n: Int) -> a:
  match combine_n_Semigroup(semigroup_item, value, n):
    case Some(combined):
      combined
    case None:
      value

def combine_map_all_Bool_and(head: a, tail: List[a], fn: a -> Bool) -> Bool:
  def go(rem: List[a]) -> Bool:
    loop rem:
      case []:
        True
      case [next, *rest]:
        if fn(next):
          go(rest)
        else:
          False
  if fn(head):
    go(tail)
  else:
    False

def combine_map_all_Bool_or(head: a, tail: List[a], fn: a -> Bool) -> Bool:
  def go(rem: List[a]) -> Bool:
    loop rem:
      case []:
        False
      case [next, *rest]:
        if fn(next):
          True
        else:
          go(rest)
  if fn(head):
    True
  else:
    go(tail)

semigroup_Bool_and: Semigroup[Bool] = semigroup_specialized(
  and_Bool,
  (value, _) -> value,
  combine_map_all_Bool_and,
)
monoid_Bool_and: Monoid[Bool] = monoid_from_semigroup(True, semigroup_Bool_and)

semigroup_Bool_or: Semigroup[Bool] = semigroup_specialized(
  or_Bool,
  (value, _) -> value,
  combine_map_all_Bool_or,
)
monoid_Bool_or: Monoid[Bool] = monoid_from_semigroup(False, semigroup_Bool_or)

semigroup_Int_add: Semigroup[Int] = semigroup_from_combine((left, right) -> left.add(right))
semigroup_Int_mul: Semigroup[Int] = semigroup_from_combine((left, right) -> left.mul(right))
monoid_Int_add: Monoid[Int] = monoid_from_semigroup(0, semigroup_Int_add)
monoid_Int_mul: Monoid[Int] = monoid_from_semigroup(1, semigroup_Int_mul)

semigroup_Float64_add: Semigroup[Float64] = semigroup_from_combine(addf)
semigroup_Float64_mul: Semigroup[Float64] = semigroup_from_combine(timesf)
monoid_Float64_add: Monoid[Float64] = monoid_from_semigroup(0.0, semigroup_Float64_add)
monoid_Float64_mul: Monoid[Float64] = monoid_from_semigroup(1.0, semigroup_Float64_mul)

semigroup_String: Semigroup[String] = (
    combine = (l, r) -> concat_String([l, r])
    semigroup_specialized(
        combine,
        (str, n) -> combine_n_positive_from_combine(combine, str, n),
        (head, tail, fn) -> (
            parts_rev = tail.foldl_List([fn(head)], (acc, item) -> [fn(item), *acc])
            concat_String(parts_rev.reverse())
        )
    )
)
monoid_String: Monoid[String] = monoid_from_semigroup("", semigroup_String)

def eq_Option(eq_item: Eq[a]) -> Eq[Option[a]]:
  eq_from_fn((left, right) -> (
    match (left, right):
      case (Some(left_v), Some(right_v)):
        eq_Eq(eq_item, left_v, right_v)
      case (None, None):
        True
      case _:
        False
  ))

def ord_Option(ord_item: Ord[a]) -> Ord[Option[a]]:
  ord_from_cmp((left, right) -> (
    match (left, right):
      case (None, None):
        EQ
      case (None, Some(_)):
        LT
      case (Some(_), None):
        GT
      case (Some(left_v), Some(right_v)):
        cmp_Ord(ord_item, left_v, right_v)
  ))

def hash_Option(hash_item: Hash[a]) -> Hash[Option[a]]:
  eq_item = hash_to_Eq(hash_item)
  hash_specialized((value) -> (
    match value:
      case None:
        finish_61(hash_seed_option_none, 0, hash_tag_option_none)
      case Some(item):
        finish_61(mix_61(hash_seed_option_some, hash_Hash(hash_item, item)), 1, hash_tag_option_some)
  ), eq_Option(eq_item))

def semigroup_Option(semigroup_item: Semigroup[a]) -> Semigroup[Option[a]]:
  combine_option = (left, right) -> (
    match (left, right):
      case (Some(left_v), Some(right_v)):
        Some(combine_Semigroup(semigroup_item, left_v, right_v))
      case (Some(_), None):
        left
      case (None, Some(_)):
        right
      case (None, None):
        None
  )
  semigroup_specialized(
    combine_option,
    (value, n) -> (
      match value:
        case None:
          None
        case Some(item):
          match combine_n_Semigroup(semigroup_item, item, n):
            case Some(combined):
              Some(combined)
            case None:
              None
    ),
    (head, tail, fn) -> (
      present_rev = tail.foldl_List(
        match fn(head):
          case None:
            []
          case Some(item):
            [item],
        (acc, item) -> (
          match fn(item):
            case None:
              acc
            case Some(mapped_item):
              [mapped_item, *acc]
        ),
      )
      match present_rev.reverse():
        case []:
          None
        case [present_head, *present_tail]:
          Some(combine_map_all_Semigroup(semigroup_item, present_head, present_tail, item -> item))
    ),
  )

def monoid_Option(semigroup_item: Semigroup[a]) -> Monoid[Option[a]]:
  monoid_from_semigroup(None, semigroup_Option(semigroup_item))

def eq_List(eq_item: Eq[a]) -> Eq[List[a]]:
  eq_List_Collection(eq_item)

def ord_List(ord_item: Ord[a]) -> Ord[List[a]]:
  ord_List_Collection(ord_item)

def hash_List(hash_item: Hash[a]) -> Hash[List[a]]:
  eq_item = hash_to_Eq(hash_item)
  hash_specialized(
    (value) -> hash_list(hash_item, hash_seed_list, hash_tag_list, value),
    eq_List(eq_item),
  )

list_concat_semigroup: Semigroup[List[a]] = semigroup_from_combine((left, right) -> left.concat(right))

def combine_map_all_List(head: b, tail: List[b], fn: b -> List[a]) -> List[a]:
  def prepend_chunk_reverse(chunk: List[a], rev_total: List[a]) -> List[a]:
    chunk.foldl_List(rev_total, (acc, item) -> [item, *acc])
  # Build reverse of the final concatenation in one pass, then reverse once.
  rev_total = tail.foldl_List(prepend_chunk_reverse(fn(head), []), (acc, item) -> prepend_chunk_reverse(fn(item), acc))
  rev_total.reverse()

semigroup_List: Semigroup[List[a]] = semigroup_specialized(
  (left, right) -> left.concat(right),
  (value, n) -> combine_n_positive_or_self(list_concat_semigroup, value, n),
  combine_map_all_List,
)
monoid_List: Monoid[List[a]] = monoid_from_semigroup([], semigroup_List)

def foldr_Array(items: Array[a], init: b, fn: (a, b) -> b) -> b:
  cnt = size_Array(items)
  def go(rem: Int, idx: Int, acc: b) -> b:
    loop rem:
      case _ if cmp_Int(rem, 0) matches LT | EQ:
        acc
      case _:
        match get_Array(items, idx):
          case Some(item):
            go(rem.sub(1), idx.sub(1), fn(item, acc))
          case None:
            acc
  go(cnt, cnt.sub(1), init)

foldable_Array: Foldable[Array] = foldable_specialized(
  foldl_Array,
  foldr_Array,
  (items, monoid, fn) -> foldl_Array(items, empty_Monoid(monoid), (acc, item) -> combine_Monoid(monoid, acc, fn(item))),
  foldl_state_Array,
  foldr_state_Array,
  (items) -> cmp_Int(size_Array(items), 0) matches EQ,
  size_Array,
  to_List_Array,
)

def foldl_iter(items: List[a], init: b, fn: (b, a) -> IterState[b, b]) -> IterState[b, b]:
  foldl_state_List(items, init, fn)

def foldr_iter(items: List[a], init: b, fn: (a, b) -> IterState[b, b]) -> IterState[b, b]:
  foldr_state_List(items, init, fn)

foldable_List: Foldable[List] = foldable_specialized(
  foldl_List,
  foldr_List,
  (items, monoid, fn) -> combine_map_all_Monoid(monoid, items, fn),
  foldl_iter,
  foldr_iter,
  is_empty_List,
  size_List,
  items -> items,
)

foldable_Option: Foldable[Option] = foldable_from_folds(
  (value, init, fn) -> (
    match value:
      case Some(item):
        fn(init, item)
      case None:
        init
  ),
  (value, init, fn) -> (
    match value:
      case Some(item):
        fn(item, init)
      case None:
        init
  ),
)

def traverse_Option_fn[g: * -> *, a, b](value: Option[a], app: Applicative[g], fn: a -> g[b]) -> g[Option[b]]:
  match value:
    case Some(item):
      fn(item).map(app, Some)
    case None:
      app.pure(None)

def traverse_Array_fn[g: * -> *, a, b](items: Array[a], app: Applicative[g], fn: a -> g[b]) -> g[Array[b]]:
  rev_mapped = foldl_Array(
    items,
    app.pure([]),
    (acc, item) -> app.map2(acc, fn(item), (rev_items, mapped_item) -> [mapped_item, *rev_items]),
  )
  rev_mapped.map(app, rev_items -> from_List_Array(rev_items.reverse()))

def keep_even_Option_Int(value: Int) -> Option[Int]:
  if cmp_Int(mod_Int(value, 2), 0) matches EQ:
    Some(value)
  else:
    None

traverse_Array: Traverse[Array] = traverse_specialized(
  traverse_Array_fn,
  map_Array,
  foldable_Array,
)

def map_Option_Applicative(value: Option[a], fn: a -> b) -> Option[b]:
  match value:
    case Some(item):
      Some(fn(item))
    case None:
      None

def map2_Option_Applicative(left: Option[a], right: Option[b], fn: (a, b) -> c) -> Option[c]:
  match (left, right):
    case (Some(left_value), Some(right_value)):
      Some(fn(left_value, right_value))
    case _:
      None

traverse_Option: Traverse[Option] = traverse_specialized(
  traverse_Option_fn,
  map_Option_Applicative,
  foldable_Option,
)

applicative_Option: Applicative[Option] = applicative_from_pure_map_map2(
  Some,
  map_Option_Applicative,
  map2_Option_Applicative,
)

def map_Prog_Applicative(prog: Prog[e, a], fn: a -> b) -> Prog[e, b]:
  value <- prog.await()
  pure_Prog(fn(value))

def map2_Prog_Applicative(left: Prog[e, a], right: Prog[e, b], fn: (a, b) -> c) -> Prog[e, c]:
  left_value <- left.await()
  right_value <- right.await()
  pure_Prog(fn(left_value, right_value))

applicative_Prog: forall e. Applicative[Prog[e]] = applicative_from_pure_map_map2(
  pure_Prog,
  map_Prog_Applicative,
  map2_Prog_Applicative,
)

def flat_map_Option_Monad(value: Option[a], fn: a -> Option[b]) -> Option[b]:
  match value:
    case Some(item):
      fn(item)
    case None:
      None

def tailrec_steps_Option_Monad(
  max_steps: Int,
  init: a,
  step: a -> Option[IterState[a, b]],
) -> Option[IterState[a, b]]:
  def go(rem: Int, seed: a) -> Option[IterState[a, b]]:
    loop rem:
      case _ if cmp_Int(rem, 0) matches LT | EQ:
        Some(continue(seed))
      case _:
        # Keep recursion in tail position so `loop` can compile to an actual while loop.
        # This intentionally inlines Option flat_map for stack-safe long stepping.
        match step(seed):
          case Some(Done(done_value)):
            Some(done(done_value))
          case Some(Continue(next_seed)):
            go(rem.sub(1), next_seed)
          case None:
            None
  go(max_steps, init)

monad_Option: Monad[Option] = monad_from_applicative_flat_map_tailrec_steps(
  applicative_Option,
  flat_map_Option_Monad,
  tailrec_steps_Option_Monad,
)

def flat_map_Prog_Monad(prog: Prog[e, a], fn: a -> Prog[e, b]) -> Prog[e, b]:
  value <- prog.await()
  fn(value)

def tailrec_steps_Prog_Monad(
  max_steps: Int,
  init: a,
  step: a -> Prog[e, IterState[a, b]],
) -> Prog[e, IterState[a, b]]:
  def go(rem: Int, seed: a) -> Prog[e, IterState[a, b]]:
    recur rem:
      case _ if cmp_Int(rem, 0) matches LT | EQ:
        pure_Prog(continue(seed))
      case _:
        state <- step(seed).await()
        match state:
          case Done(done_value):
            pure_Prog(done(done_value))
          case Continue(next_seed):
            go(rem.sub(1), next_seed)
  go(max_steps, init)

monad_Prog: forall e. Monad[Prog[e]] = monad_from_applicative_flat_map_tailrec_steps(
  applicative_Prog,
  flat_map_Prog_Monad,
  tailrec_steps_Prog_Monad,
)

