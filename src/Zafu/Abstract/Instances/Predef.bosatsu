def and_Bool(left: Bool, right: Bool) -> Bool:
  if left:
    right
  else:
    False

def cmp_then(first: Comparison, next: () -> Comparison) -> Comparison:
  if first matches EQ:
    next()
  else:
    first

def cmp_Bool(left: Bool, right: Bool) -> Comparison:
  match (left, right):
    case (False, True):
      LT
    case (True, False):
      GT
    case _:
      EQ

def rank_Comparison(value: Comparison) -> Int:
  match value:
    case LT:
      0
    case EQ:
      1
    case GT:
      2

def cmp_Comparison(left: Comparison, right: Comparison) -> Comparison:
  cmp_Int(rank_Comparison(left), rank_Comparison(right))

def eq_list(eq_item: Eq[a], left: List[a], right: List[a]) -> Bool:
  def go(left: List[a], right: List[a]) -> Bool:
    loop (left, right):
      case ([], []):
        True
      case ([left_h, *left_t], [right_h, *right_t]):
        if eq_Eq(eq_item, left_h, right_h):
          go(left_t, right_t)
        else:
          False
      case _:
        False
  go(left, right)

def cmp_list(ord_item: Ord[a], left: List[a], right: List[a]) -> Comparison:
  def go(left: List[a], right: List[a]) -> Comparison:
    loop (left, right):
      case ([], []):
        EQ
      case ([], [_, *_]):
        LT
      case ([_, *_], []):
        GT
      case ([left_h, *left_t], [right_h, *right_t]):
        head_cmp = cmp_Ord(ord_item, left_h, right_h)
        if head_cmp matches EQ:
          go(left_t, right_t)
        else:
          head_cmp
  go(left, right)

hash_tag_unit: Int = 1009
hash_tag_bool_false: Int = 1013
hash_tag_bool_true: Int = 1019
hash_seed_comparison: Int = 1031
hash_tag_comparison: Int = 1033
hash_float64_nan: Int = 1039
hash_float64_zero: Int = 1049
hash_seed_string: Int = 1061
hash_tag_string: Int = 1063
hash_seed_option_none: Int = 1091
hash_tag_option_none: Int = 1093
hash_seed_option_some: Int = 1097
hash_tag_option_some: Int = 1103
hash_seed_list: Int = 1123
hash_tag_list: Int = 1129
hash_tuple_seed_base: Int = 1201
hash_tuple_tag_base: Int = 1301
hash_tag_dict: Int = 1409

def hash_list(hash_item: Hash[a], seed: Int, tag: Int, value: List[a]) -> Int:
  def go(rem: List[a], acc: Int, size: Int) -> Int:
    loop rem:
      case []:
        finish_61(acc, size, tag)
      case [head, *tail]:
        go(tail, mix_61(acc, hash_Hash(hash_item, head)), size.add(1))
  go(value, seed, 0)

def hash_string_value(value: String) -> Int:
  # Eq/String compares UTF-8 byte sequences, so hashing bytes preserves coherence.
  bytes = utf8_bytes_from_String(value)
  mixed = foldl_Bytes(bytes, hash_seed_string, (acc, byte) -> mix_61(acc, normalize_61(byte)))
  finish_61(mixed, size_Bytes(bytes), hash_tag_string)

ord_Unit: Ord[Unit] = ord_from_cmp((_, _) -> EQ)
eq_Unit: Eq[Unit] = ord_to_eq(ord_Unit)
hash_Unit: Hash[Unit] = hash_specialized(_ -> hash_tag_unit, eq_Unit)

ord_Bool: Ord[Bool] = ord_from_cmp(cmp_Bool)
eq_Bool: Eq[Bool] = ord_to_eq(ord_Bool)
hash_Bool: Hash[Bool] = hash_specialized(
  (value) -> (
    if value:
      hash_tag_bool_true
    else:
      hash_tag_bool_false
  ),
  eq_Bool,
)

ord_Char: Ord[Char] = ord_from_cmp(cmp_Char)
eq_Char: Eq[Char] = ord_to_eq(ord_Char)
hash_Char: Hash[Char] = hash_from_fn(char_to_Int, eq_Char)

ord_Comparison: Ord[Comparison] = ord_from_cmp(cmp_Comparison)
eq_Comparison: Eq[Comparison] = ord_to_eq(ord_Comparison)
hash_Comparison: Hash[Comparison] = hash_specialized(
  value -> finish_61(hash_seed_comparison, rank_Comparison(value), hash_tag_comparison),
  eq_Comparison,
)

ord_Int: Ord[Int] = ord_from_cmp(cmp_Int)
eq_Int: Eq[Int] = ord_to_eq(ord_Int)
hash_Int: Hash[Int] = hash_from_fn(value -> value, eq_Int)

ord_Float64: Ord[Float64] = ord_from_cmp(cmp_Float64)
eq_Float64: Eq[Float64] = ord_to_eq(ord_Float64)
hash_Float64: Hash[Float64] = hash_specialized(
  (value) -> (
    # cmp_Float64 treats all NaNs and both signed zeros as equal.
    if is_nan(value):
      hash_float64_nan
    else:
      if cmp_Float64(value, 0.0) matches EQ:
        hash_float64_zero
      else:
        normalize_61(float64_bits_to_Int(value))
  ),
  eq_Float64,
)

ord_String: Ord[String] = ord_from_cmp(cmp_String)
eq_String: Eq[String] = ord_to_eq(ord_String)
hash_String: Hash[String] = hash_specialized(hash_string_value, eq_String)

def eq_Option(eq_item: Eq[a]) -> Eq[Option[a]]:
  eq_from_fn((left, right) -> (
    match (left, right):
      case (Some(left_v), Some(right_v)):
        eq_Eq(eq_item, left_v, right_v)
      case (None, None):
        True
      case _:
        False
  ))

def ord_Option(ord_item: Ord[a]) -> Ord[Option[a]]:
  ord_from_cmp((left, right) -> (
    match (left, right):
      case (None, None):
        EQ
      case (None, Some(_)):
        LT
      case (Some(_), None):
        GT
      case (Some(left_v), Some(right_v)):
        cmp_Ord(ord_item, left_v, right_v)
  ))

def hash_Option(hash_item: Hash[a]) -> Hash[Option[a]]:
  eq_item = hash_to_Eq(hash_item)
  hash_specialized((value) -> (
    match value:
      case None:
        finish_61(hash_seed_option_none, 0, hash_tag_option_none)
      case Some(item):
        finish_61(mix_61(hash_seed_option_some, hash_Hash(hash_item, item)), 1, hash_tag_option_some)
  ), eq_Option(eq_item))

def eq_List(eq_item: Eq[a]) -> Eq[List[a]]:
  eq_from_fn((left, right) -> eq_list(eq_item, left, right))

def ord_List(ord_item: Ord[a]) -> Ord[List[a]]:
  ord_from_cmp((left, right) -> cmp_list(ord_item, left, right))

def hash_List(hash_item: Hash[a]) -> Hash[List[a]]:
  eq_item = hash_to_Eq(hash_item)
  hash_specialized(
    (value) -> hash_list(hash_item, hash_seed_list, hash_tag_list, value),
    eq_List(eq_item),
  )

def eq_Tuple1(eq1: Eq[a1]) -> Eq[Tuple1[a1]]:
  eq_from_fn((left, right) -> (
    match (left, right):
      case (Tuple1(left1), Tuple1(right1)):
        eq_Eq(eq1, left1, right1)
  ))

def ord_Tuple1(ord1: Ord[a1]) -> Ord[Tuple1[a1]]:
  ord_from_cmp((left, right) -> (
    match (left, right):
      case (Tuple1(left1), Tuple1(right1)):
        cmp_Ord(ord1, left1, right1)
  ))

def eq_Tuple2(eq1: Eq[a1], eq2: Eq[a2]) -> Eq[Tuple2[a1, a2]]:
  eq_from_fn((left, right) -> (
    match (left, right):
      case (Tuple2(left1, left2), Tuple2(right1, right2)):
        and_Bool(eq_Eq(eq1, left1, right1), eq_Eq(eq2, left2, right2))
  ))

def ord_Tuple2(ord1: Ord[a1], ord2: Ord[a2]) -> Ord[Tuple2[a1, a2]]:
  ord_from_cmp((left, right) -> (
    match (left, right):
      case (Tuple2(left1, left2), Tuple2(right1, right2)):
        cmp_then(cmp_Ord(ord1, left1, right1), () -> cmp_Ord(ord2, left2, right2))
  ))

