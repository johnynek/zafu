    Assertion(combine_Monoid(option_monoid, None, Some(2)) matches Some(2), "monoid_Option keeps present side")
  ),
  Assertion(
    combine_all_Monoid(monoid_List, [[], [1, 2], [3, 4]]) matches [1, 2, 3, 4],
