package Zafu/Testing/HedgeHog/Tree

from Zafu/Collection/LazyList import (
  LazyList,
  empty_LazyList,
  concat_lazy,
  map as map_LazyList,
  Cons as ConsLazyList,
  Empty as EmptyLazyList,
)

from Bosatsu/Lazy import get_Lazy, lazy, Lazy

export (
  Tree,
  expand_Tree,
  flat_map_Tree,
  map_Tree,
  prune_Tree,
  singleton,
  unfold_Tree,
)

struct Tree(value: a, children: LazyList[Tree[a]])

def singleton(value: a) -> Tree[a]:
  Tree(value, empty_LazyList)

def map_Tree(tree: Tree[a], fn: a -> b) -> Tree[b]:
    def map_Trees(trees: LazyList[Tree[a]]) -> LazyList[Tree[b]]:
        recur trees:
            case EmptyLazyList: EmptyLazyList
            case ConsLazyList(head, tail):
                mapped_head = lazy(() -> (
                    Tree(h, hs) = get_Lazy(head)
                    Tree(fn(h), map_Trees(hs))
                ))
                mapped_tail = lazy(() -> map_Trees(get_Lazy(tail)))
                ConsLazyList(mapped_head, mapped_tail)

    Tree(v, c) = tree
    Tree(fn(v), map_Trees(c))

def flat_map_Tree(tree: Tree[a], fn: a -> Tree[b]) -> Tree[b]:
    def flat_map_Trees(trees: LazyList[Tree[a]]) -> LazyList[Tree[b]]:
        recur trees:
            case EmptyLazyList: EmptyLazyList
            case ConsLazyList(head, tail):
                mapped_head = lazy(() -> (
                    Tree(h, hs) = get_Lazy(head)
                    Tree(h1, hs1) = fn(h)
                    Tree(h1, hs1.concat_lazy(lazy(() -> flat_map_Trees(hs))))
                ))
                mapped_tail = lazy(() -> flat_map_Trees(get_Lazy(tail)))
                ConsLazyList(mapped_head, mapped_tail)
    Tree(value, children) = tree
    Tree(mapped_value, mapped_children) = fn(value)
    Tree(mapped_value, mapped_children.concat_lazy(lazy(() -> flat_map_Trees(children))))

# Build up a Tree from an initial value, an injection to the tree type, and an expansion
# of at most a given depth. If the depth is <= 0, we only get one value
def unfold_Tree(depth: Int, init: b, inject: b -> a, expand: b -> LazyList[b]) -> Tree[a]:
    def unfold_forest(depth: Int, bs: LazyList[b]) -> LazyList[Tree[a]]:
        recur (depth, bs):
            case _ if cmp_Int(depth, 0) matches LT | EQ: EmptyLazyList
            case (_, EmptyLazyList): EmptyLazyList
            case (_, ConsLazyList(head, tail)):
                uhead = lazy(() ->
                    head_b = get_Lazy(head)
                    ha = inject(head_b)
                    children = expand(head_b)
                    # this depth recursion requires proof of termination
                    Tree(ha, unfold_forest(depth.sub(1), children))
                )
                # this breadth recursion doesn't cost depth
                utail = lazy(() -> unfold_forest(depth, get_Lazy(tail)))
                ConsLazyList(uhead, utail)

    inj_init = inject(init)
    children = unfold_forest(depth, expand(init))
    Tree(inj_init, children)

def expand_Tree(tree: Tree[a], depth: Int, expand: a -> LazyList[a]) -> Tree[a]:
    recur depth:
        case _ if cmp_Int(depth, 0) matches LT | EQ: tree
        case _:
            Tree(root, children) = tree
            lhs = children.map_LazyList(child -> expand_Tree(child, depth.sub(1), expand))
            new_children = lhs.concat_lazy(lazy(() ->
                Tree(_, new_children) = unfold_Tree(depth, root, a -> a, expand)
                new_children
            ))
            Tree(root, new_children)
    

def prune_Tree(tree: Tree[a]) -> Tree[a]:
  Tree(value, _) = tree
  Tree(value, empty_LazyList)
