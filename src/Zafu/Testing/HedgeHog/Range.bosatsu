package Zafu/Testing/HedgeHog/Range

from Bosatsu/Collection/Array import (
  from_List_Array,
  size_Array,
  get_Array,
)

from Zafu/Testing/HedgeHog/Seed import (
  Seed,
  choose_Int,
  from_Int as seed_from_Int,
)
from Zafu/Testing/HedgeHog/Size import (
  Size,
  from_Int as size_from_Int,
  max as max_Size,
  to_Int,
)

export (
  Range,
  constant_Range,
  linear_Range,
  lower_bound,
  upper_bound,
  sample_Int,
  one_of_Int,
  int8_signed_Range,
  int16_signed_Range,
  int32_signed_Range,
  int64_signed_Range,
  int128_signed_Range,
  uint32_Range,
  pos_int8_Range,
  pos_int16_Range,
  pos_int32_Range,
)

# Size-sensitive integer range with an origin and bound scaling rule.
struct Range(origin: Int, bounds_fn: Size -> (Int, Int))

def normalize_bounds(lower: Int, upper_exclusive: Int) -> (Int, Int):
  if cmp_Int(upper_exclusive, lower) matches GT:
    (lower, upper_exclusive)
  else:
    (lower, lower.add(1))

def scale_from(origin: Int, target: Int, size: Size) -> Int:
  delta = target.sub(origin)
  origin.add(delta.mul(size.to_Int()).div(max_Size()))

def default_origin(lower: Int, upper_exclusive: Int) -> Int:
  if cmp_Int(lower, 0) matches GT | EQ:
    lower
  elif cmp_Int(upper_exclusive, 0) matches LT | EQ:
    upper_exclusive.sub(1)
  else:
    0

def bounds(range: Range, size: Size) -> (Int, Int):
  Range(_, bounds_fn) = range
  bounds_fn(size)

def and_Bool(left: Bool, right: Bool) -> Bool:
  if left:
    right
  else:
    False

# Return the current lower bound for a size.
def lower_bound(range: Range, size: Size) -> Int:
  (lower, _) = bounds(range, size)
  lower

# Return the current exclusive upper bound for a size.
def upper_bound(range: Range, size: Size) -> Int:
  (_, upper_exclusive) = bounds(range, size)
  upper_exclusive

# Build a size-independent range with fixed inclusive/exclusive bounds.
def constant_Range(lower: Int, upper_exclusive: Int) -> Range:
  (lower1, upper1) = normalize_bounds(lower, upper_exclusive)
  Range(lower1, _ -> (lower1, upper1))

# Build a range whose bounds scale from an origin toward the target interval.
def linear_from_Range(origin: Int, lower: Int, upper_exclusive: Int) -> Range:
  (lower1, upper1) = normalize_bounds(lower, upper_exclusive)
  Range(origin, size -> normalize_bounds(
    scale_from(origin, lower1, size),
    scale_from(origin, upper1, size),
  ))

# Build a linearly size-scaled range with a derived origin.
def linear_Range(lower: Int, upper_exclusive: Int) -> Range:
  linear_from_Range(default_origin(lower, upper_exclusive), lower, upper_exclusive)

# Sample an integer from the range at the given size.
def sample_Int(range: Range, size: Size, seed: Seed) -> (Seed, Int):
  (lower, upper_exclusive) = normalize_bounds(range.lower_bound(size), range.upper_bound(size))
  choose_Int(seed, lower, upper_exclusive.sub(1))

# Build a size-aware sampler that chooses one of several ranges uniformly first.
def one_of_Int(first: Range, rest: List[Range]) -> Size -> Seed -> (Seed, Int):
  ranges = from_List_Array([first, *rest])
  last_idx = size_Array(ranges).sub(1)
  size -> seed -> (
    (seed1, idx) = choose_Int(seed, 0, last_idx)
    match get_Array(ranges, idx):
      case Some(range):
        sample_Int(range, size, seed1)
      case None:
        sample_Int(first, size, seed1)
  )

# Size-scaled signed 8-bit integer range.
int8_signed_Range = linear_Range(0.sub(shift_left_Int(1, 7)), shift_left_Int(1, 7))
# Size-scaled signed 16-bit integer range.
int16_signed_Range = linear_Range(0.sub(shift_left_Int(1, 15)), shift_left_Int(1, 15))
# Size-scaled signed 32-bit integer range.
int32_signed_Range = linear_Range(0.sub(shift_left_Int(1, 31)), shift_left_Int(1, 31))
# Size-scaled signed 64-bit integer range.
int64_signed_Range = linear_Range(0.sub(shift_left_Int(1, 63)), shift_left_Int(1, 63))
# Size-scaled signed 128-bit integer range.
int128_signed_Range = linear_Range(0.sub(shift_left_Int(1, 127)), shift_left_Int(1, 127))

# Size-scaled unsigned 32-bit integer range.
uint32_Range = linear_Range(0, shift_left_Int(1, 32))

# Size-scaled positive 8-bit integer range.
pos_int8_Range = linear_Range(1, shift_left_Int(1, 8))
# Size-scaled positive 16-bit integer range.
pos_int16_Range = linear_Range(1, shift_left_Int(1, 16))
# Size-scaled positive 32-bit integer range.
pos_int32_Range = linear_Range(1, shift_left_Int(1, 31))

tests = TestSuite("Zafu/Testing/HedgeHog/Range tests", [
  Assertion(
    constant_Range(5, 11).lower_bound(size_from_Int(1)).eq_Int(5),
    "constant lower bound",
  ),
  Assertion(
    constant_Range(5, 11).upper_bound(size_from_Int(99)).eq_Int(11),
    "constant upper bound",
  ),
  Assertion(
    linear_Range(0, 10).upper_bound(size_from_Int(1)).eq_Int(1),
    "linear range starts small",
  ),
  Assertion(
    linear_Range(0, 10).upper_bound(size_from_Int(100)).eq_Int(10),
    "linear range reaches max bound",
  ),
  (
    sample_range = linear_Range(-10, 11)
    sample_size = size_from_Int(50)
    (_, sampled_value) = sample_Int(sample_range, sample_size, seed_from_Int(7))
    lower = sample_range.lower_bound(sample_size)
    upper = sample_range.upper_bound(sample_size)
    Assertion(
      and_Bool(
        cmp_Int(sampled_value, lower) matches GT | EQ,
        cmp_Int(sampled_value, upper) matches LT,
      ),
      "sample_Int stays in bounds",
    )
  ),
])
