package Zafu/Testing/HedgeHog

from Bosatsu/Char import (
  char_to_Int,
  int_to_Char,
  string_to_Int_List,
  int_List_to_String,
)
from Bosatsu/List import eq_List
from Bosatsu/Num/Float64 import (
  float64_to_Int,
  float64_to_String,
  int_to_Float64,
)
from Bosatsu/Rand import (
  Rand,
  int_range,
  const_Rand,
  map_Rand,
  flat_map_Rand,
  prod_Rand,
  sequence_Rand,
  run_Rand,
)

export (
  Gen,
  gen_Rand,
  shrink_Gen,
  no_shrink_Gen,
  const_Gen,
  map_Gen,
  flat_map_Gen,
  unit_Gen,
  bool_Gen,
  comparison_Gen,
  int_Gen,
  char_Gen,
  string_Gen,
  float64_Gen,
  option_Gen,
  list_Gen,
  tuple2_Gen,
  Prop,
  forall_Prop,
  suite_Prop,
  run_Prop,
)

enum Gen:
  Gen(rand: Rand[a], shrink: a -> List[a])

def gen_Rand(gen: Gen[a]) -> Rand[a]:
  match gen:
    case Gen(rand, _):
      rand

def shrink_Gen(gen: Gen[a]) -> a -> List[a]:
  match gen:
    case Gen(_, shrink):
      shrink

def no_shrink_Gen(rand: Rand[a]) -> Gen[a]:
  Gen(rand, _ -> [])

def const_Gen(value: a) -> Gen[a]:
  no_shrink_Gen(const_Rand(value))

def and_Bool(left: Bool, right: Bool) -> Bool:
  if left:
    right
  else:
    False

def not_Bool(value: Bool) -> Bool:
  if value:
    False
  else:
    True

def map_Gen(gen: Gen[a], fn: a -> b) -> Gen[b]:
  no_shrink_Gen(map_Rand(gen.gen_Rand(), fn))

def flat_map_Gen(gen: Gen[a], fn: a -> Gen[b]) -> Gen[b]:
  no_shrink_Gen(flat_map_Rand(gen.gen_Rand(), a -> fn(a).gen_Rand()))

def test_passes(test: Test) -> Bool:
  (_, _, passed) = int_loop(4096, ([test], False, True), (rem, state) -> (
    (stack, done, passed) = state
    if done:
      (0, state)
    else:
      match stack:
        case []:
          (0, (stack, True, passed))
        case [head, *tail]:
          match head:
            case Assertion(value, _):
              if value:
                (rem.sub(1), (tail, False, passed))
              else:
                (0, (tail, True, False))
            case TestSuite(_, tests):
              (rem.sub(1), (tests.concat(tail), False, passed))
  ))
  passed

def first_failure_message(test: Test) -> Option[String]:
  (_, _, message) = int_loop(4096, ([test], False, None), (rem, state) -> (
    (stack, done, message) = state
    if done:
      (0, state)
    else:
      match stack:
        case []:
          (0, (stack, True, message))
        case [head, *tail]:
          match head:
            case Assertion(value, msg):
              if value:
                (rem.sub(1), (tail, False, message))
              else:
                (0, (tail, True, Some(msg)))
            case TestSuite(_, tests):
              (rem.sub(1), (tests.concat(tail), False, message))
  ))
  message

def first_failing(values: List[a], test_fn: a -> Test) -> Option[a]:
  loop values:
    case []:
      None
    case [head, *tail]:
      if test_fn(head).test_passes():
        first_failing(tail, test_fn)
      else:
        Some(head)

def shrink_to_smallest(start: a, shrink: a -> List[a], test_fn: a -> Test) -> a:
  int_loop(128, start, (rem, current) -> (
    match first_failing(shrink(current), test_fn):
      case None:
        (0, current)
      case Some(next):
        (rem.sub(1), next)
  ))

def first_failure_and_shrunk_samples(samples: List[a], gen: Gen[a], test_fn: a -> Test) -> Option[(a, a)]:
  loop samples:
    case []:
      None
    case [head, *tail]:
      test = test_fn(head)
      if test.test_passes():
        first_failure_and_shrunk_samples(tail, gen, test_fn)
      else:
        Some((head, shrink_to_smallest(head, gen.shrink_Gen(), test_fn)))

def first_failure_and_shrunk(gen: Gen[a], count: Int, seed: Int, test_fn: a -> Test) -> Option[(a, a)]:
  samples = run_Rand(sequence_Rand(replicate_List(gen.gen_Rand(), count)), seed)
  first_failure_and_shrunk_samples(samples, gen, test_fn)

def render_failure(name: String, show: a -> String, original: a, shrunk: a, message: Option[String]) -> String:
  base = "${name} failed (original=${show(original)}, shrunk=${show(shrunk)})"
  match message:
    case None:
      base
    case Some(extra):
      if length_String(extra).eq_Int(0):
        base
      else:
        "${base}: ${extra}"

def list_size_loop(list: List[a], acc: Int) -> Int:
  loop list:
    case []:
      acc
    case [_, *tail]:
      list_size_loop(tail, acc.add(1))

def list_size(list: List[a]) -> Int:
  list_size_loop(list, 0)

def abs_Int(i: Int) -> Int:
  if cmp_Int(i, 0) matches LT:
    0.sub(i)
  else:
    i

def sign_Int(i: Int) -> Int:
  if cmp_Int(i, 0) matches LT:
    -1
  elif i.eq_Int(0):
    0
  else:
    1

def shrink_Int(i: Int) -> List[Int]:
  if i.eq_Int(0):
    []
  else:
    half = i.div(2)
    one = sign_Int(i)
    if half.eq_Int(0):
      [0]
    elif half.eq_Int(one):
      [0, one]
    else:
      [0, half, one]

def shrink_List(shrink_item)(list: List[a]) -> List[List[a]]:
  match list:
    case []:
      []
    case [head, *tail]:
      head_shrinks = shrink_item(head).map_List(h -> [h, *tail])
      [[], tail].concat(head_shrinks)

def to_ascii_Char(i: Int) -> Char:
  match int_to_Char(i):
    case Some(c):
      c
    case None:
      .'a'

def shrink_Char(char: Char) -> List[Char]:
  int_values = shrink_Int(char_to_Int(char))
  int_values.foldl_List([], (acc, i) -> (
    match int_to_Char(i):
      case Some(c):
        [c, *acc]
      case None:
        acc
  )).reverse()

def int_List_to_String_or_empty(list: List[Int]) -> String:
  match int_List_to_String(list):
    case Some(str):
      str
    case None:
      ""

def shrink_String(str: String) -> List[String]:
  ints = string_to_Int_List(str)
  shrink_List(shrink_Int)(ints).foldl_List([], (acc, int_list) -> (
    match int_List_to_String(int_list):
      case Some(s):
        [s, *acc]
      case None:
        acc
  )).reverse()

def shrink_Option(shrink_item)(value: Option[a]) -> List[Option[a]]:
  match value:
    case None:
      []
    case Some(item):
      [None].concat(shrink_item(item).map_List(Some))

def shrink_Tuple2(shrink_left, shrink_right)((left, right): (a, b)) -> List[(a, b)]:
  left_shrinks = shrink_left(left).map_List(l -> (l, right))
  right_shrinks = shrink_right(right).map_List(r -> (left, r))
  left_shrinks.concat(right_shrinks)

unit_Gen: Gen[Unit] = const_Gen(Unit)

bool_Gen: Gen[Bool] = Gen(
  map_Rand(int_range(2), i -> i.eq_Int(1)),
  b -> [False] if b else [],
)

comparison_Gen: Gen[Comparison] = Gen(
  map_Rand(int_range(3), i -> (
    if i.eq_Int(0):
      LT
    elif i.eq_Int(1):
      EQ
    else:
      GT
  )),
  c -> match c:
    case LT:
      []
    case EQ:
      [LT]
    case GT:
      [EQ, LT],
)

int_Gen: Gen[Int] = Gen(
  map_Rand(int_range(4096), i -> i.sub(2048)),
  shrink_Int,
)

char_Gen: Gen[Char] = Gen(
  map_Rand(int_range(95), i -> to_ascii_Char(i.add(32))),
  shrink_Char,
)

string_Gen: Gen[String] = Gen(
  flat_map_Rand(int_range(12), len -> (
    chars = replicate_List(char_Gen.gen_Rand(), len)
    map_Rand(sequence_Rand(chars), list -> (
      int_values = list.map_List(char_to_Int)
      int_List_to_String_or_empty(int_values)
    ))
  )),
  shrink_String,
)

float64_Gen: Gen[Float64] = Gen(
  map_Rand(int_Gen.gen_Rand(), int_to_Float64),
  f -> match float64_to_Int(f):
    case Some(i):
      shrink_Int(i).map_List(int_to_Float64)
    case None:
      [],
)

def option_Gen(gen: Gen[a]) -> Gen[Option[a]]:
  Gen(
    flat_map_Rand(int_range(4), i -> (
      if i.eq_Int(0):
        const_Rand(None)
      else:
        map_Rand(gen.gen_Rand(), Some)
    )),
    shrink_Option(gen.shrink_Gen()),
  )

def list_Gen(gen: Gen[a]) -> Gen[List[a]]:
  Gen(
    flat_map_Rand(int_range(10), len -> sequence_Rand(replicate_List(gen.gen_Rand(), len))),
    shrink_List(gen.shrink_Gen()),
  )

def tuple2_Gen(left: Gen[a], right: Gen[b]) -> Gen[(a, b)]:
  Gen(
    prod_Rand(left.gen_Rand(), right.gen_Rand()),
    shrink_Tuple2(left.shrink_Gen(), right.shrink_Gen()),
  )

enum Prop:
  Prop(run: Int -> Rand[Test])

def run_count(prop: Prop, count: Int) -> Rand[Test]:
  match prop:
    case Prop(run):
      run(count)

def forall_Prop(gen: Gen[a], name: String, show: a -> String, test_fn: a -> Test) -> Prop:
  Prop(count -> (
    samples_rand = sequence_Rand(replicate_List(gen.gen_Rand(), count))
    map_Rand(samples_rand, samples -> (
      match first_failure_and_shrunk_samples(samples, gen, test_fn):
        case None:
          Assertion(True, name)
        case Some((original, shrunk)):
          fail_message = first_failure_message(test_fn(shrunk))
          Assertion(False, render_failure(name, show, original, shrunk, fail_message))
    ))
  ))

def suite_Prop(name: String, props: List[Prop]) -> Prop:
  Prop(count -> (
    all_runs = [run_count(prop, count) for prop in props]
    map_Rand(sequence_Rand(all_runs), tests -> TestSuite(name, tests))
  ))

def run_Prop(prop: Prop, count: Int, seed: Int) -> Test:
  run_Rand(run_count(prop, count), seed)

def show_Bool(bool: Bool) -> String:
  if bool:
    "True"
  else:
    "False"

def show_Comparison(comp: Comparison) -> String:
  match comp:
    case LT:
      "LT"
    case EQ:
      "EQ"
    case GT:
      "GT"

def show_Char(c: Char) -> String:
  int_to_String(char_to_Int(c))

def show_Option_Int(opt: Option[Int]) -> String:
  match opt:
    case None:
      "None"
    case Some(i):
      "Some(${int_to_String(i)})"

def show_Int_List(list: List[Int]) -> String:
  "List(size=${int_to_String(list_size(list))})"

def always_valid_prop(gen: Gen[a], name: String, show: a -> String, fn: a -> Bool) -> Prop:
  forall_Prop(gen, name, show, a -> Assertion(fn(a), name))

predef_generators_prop: Prop = suite_Prop("Predef generators", [
  always_valid_prop(unit_Gen, "Unit", _ -> "Unit", _ -> True),
  always_valid_prop(bool_Gen, "Bool", show_Bool, b -> (
    expected_len = 4 if b else 5
    length_String(show_Bool(b)).eq_Int(expected_len)
  )),
  always_valid_prop(comparison_Gen, "Comparison", show_Comparison, c -> (
    idx = match c:
      case LT:
        -1
      case EQ:
        0
      case GT:
        1
    if c matches EQ:
      idx.eq_Int(0)
    else:
      abs_Int(idx).eq_Int(1)
  )),
  always_valid_prop(int_Gen, "Int reflexive", int_to_String, i -> i.eq_Int(i)),
  always_valid_prop(char_Gen, "Char round-trip", show_Char, c -> int_to_Char(char_to_Int(c)) matches Some(_)),
  always_valid_prop(string_Gen, "String round-trip", s -> s, s -> int_List_to_String(string_to_Int_List(s)) matches Some(_)),
  always_valid_prop(float64_Gen, "Float64 from Int", float64_to_String, f -> float64_to_Int(f) matches Some(_)),
  always_valid_prop(option_Gen(int_Gen), "Option[Int]", show_Option_Int, o -> (
    match o:
      case None:
        True
      case Some(i):
        i.eq_Int(i)
  )),
  always_valid_prop(list_Gen(int_Gen), "List[Int]", show_Int_List, list -> eq_List(eq_Int)(list.reverse().reverse(), list)),
  always_valid_prop(tuple2_Gen(int_Gen, bool_Gen), "Tuple2[Int, Bool]", _ -> "tuple2", ((i, b)) -> (
    i.eq_Int(i) if b else i.eq_Int(i)
  )),
])

def non_zero_int_Gen() -> Gen[Int]:
  Gen(
    map_Rand(int_range(1024), i -> i.add(1)),
    shrink_Int,
  )

def non_empty_int_list_Gen() -> Gen[List[Int]]:
  Gen(
    flat_map_Rand(int_range(8), len -> (
      list_len = len.add(1)
      sequence_Rand(replicate_List(int_Gen.gen_Rand(), list_len))
    )),
    shrink_List(shrink_Int),
  )

def shrink_int_witness() -> Test:
  match first_failure_and_shrunk(non_zero_int_Gen(), 20, 99, i -> Assertion(i.add(i).eq_Int(i), "2*x == x")):
    case None:
      Assertion(False, "expected failing int sample")
    case Some((original, shrunk)):
      small = shrunk.eq_Int(1)
      not_already_small = cmp_Int(original, 1) matches GT
      Assertion(and_Bool(small, not_already_small), "int shrink should reach 1, got ${int_to_String(shrunk)} from ${int_to_String(original)}")

def shrink_list_witness() -> Test:
  match first_failure_and_shrunk(non_empty_int_list_Gen(), 20, 123, list -> Assertion(list matches [], "expected empty list")):
    case None:
      Assertion(False, "expected failing non-empty list sample")
    case Some((original, shrunk)):
      orig_sz = list_size(original)
      shrunk_sz = list_size(shrunk)
      Assertion(and_Bool(not_Bool(orig_sz.eq_Int(0)), shrunk_sz.eq_Int(1)), "list shrink should reach size 1, got size ${int_to_String(shrunk_sz)} from ${int_to_String(orig_sz)}")

tests = TestSuite("Zafu/Testing/HedgeHog tests", [
  run_Prop(predef_generators_prop, 60, 4242),
  shrink_int_witness(),
  shrink_list_witness(),
])
