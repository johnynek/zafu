package Zafu/Testing/HedgeHog

from Bosatsu/Char import (
  char_to_Int,
  int_to_Char,
  string_to_Int_List,
  int_List_to_String,
)
from Bosatsu/List import eq_List
from Bosatsu/Num/Float64 import (
  abs,
  cmp_Float64,
  divf,
  float64_to_String,
  int_to_Float64,
  is_finite,
  subf,
)
from Bosatsu/Lazy import (
  get_Lazy,
)
from Bosatsu/Rand import (
  Rand,
  int_range,
  one_of,
  geometric_Int,
  const_Rand,
  map_Rand,
  flat_map_Rand,
  prod_Rand,
  sequence_Rand,
  run_Rand,
)
from Zafu/Collection/LazyList import (
  LazyList,
  empty_LazyList,
  lazy_singleton,
  from_List as from_List_LazyList,
  to_List as to_List_LazyList,
  map as map_LazyList,
  filter as filter_native_LazyList,
  uncons as uncons_LazyList,
)
from Zafu/Testing/HedgeHog/Range import (
  linear_Range,
  sample_Int,
  one_of_Int,
  int8_signed_Range,
  int16_signed_Range,
  int32_signed_Range,
  int64_signed_Range,
  int128_signed_Range,
  uint32_Range,
  pos_int8_Range,
  pos_int16_Range,
  pos_int32_Range,
)

export (
  Gen,
  gen_Rand,
  shrink_Gen,
  no_shrink_Gen,
  const_Gen,
  map_Gen,
  flat_map_Gen,
  unit_Gen,
  bool_Gen,
  comparison_Gen,
  int_Gen,
  int32_Gen,
  uint32_Gen,
  pos_Int_Gen,
  char_Gen,
  string_Gen,
  float64_Gen,
  option_Gen,
  list_Gen,
  tuple2_Gen,
  tuple3_Gen,
  tuple4_Gen,
  Prop,
  forall_Prop,
  suite_Prop,
  run_Prop,
)

def singleton_LazyList(item: a) -> LazyList[a]:
  lazy_singleton(() -> item)

def first_LazyList(list: LazyList[a]) -> Option[a]:
  match uncons_LazyList(list):
    case None:
      None
    case Some((head, _)):
      Some(get_Lazy(head))

struct Gen(rand: Rand[a], shrink: a -> LazyList[a])

def gen_Rand(gen: Gen[a]) -> Rand[a]:
  Gen(rand, _) = gen
  rand

def shrink_Gen(gen: Gen[a]) -> a -> LazyList[a]:
  Gen(_, shrink) = gen
  shrink

def no_shrink_Gen(rand: Rand[a]) -> Gen[a]:
  Gen(rand, _ -> empty_LazyList)

def const_Gen(value: a) -> Gen[a]:
  no_shrink_Gen(const_Rand(value))

# Preserve shrinking when the caller can provide the inverse map.
def map_Gen(gen: Gen[a], to: a -> b, from: b -> a) -> Gen[b]:
  Gen(
    map_Rand(gen.gen_Rand(), to),
    b -> map_LazyList(gen.shrink_Gen()(from(b)), to),
  )

# Preserve shrinking for flat_map by requiring the result shrinker.
def flat_map_Gen(gen: Gen[a], fn: a -> Gen[b], shrink: b -> LazyList[b]) -> Gen[b]:
  Gen(
    flat_map_Rand(gen.gen_Rand(), a -> fn(a).gen_Rand()),
    shrink,
  )

def and_Bool(left: Bool, right: Bool) -> Bool:
  if left:
    right
  else:
    False

def not_Bool(value: Bool) -> Bool:
  if value:
    False
  else:
    True

def test_passes(test: Test) -> Bool:
  def loop_tests(steps: List[Unit], todo: List[Test]) -> Bool:
    loop steps:
      case []:
        False
      case [_, *tail_steps]:
        match todo:
          case []:
            True
          case [head, *tail]:
            match head:
              case Assertion(value, _):
                if value:
                  loop_tests(tail_steps, tail)
                else:
                  False
              case TestSuite(_, tests):
                loop_tests(tail_steps, tests.concat(tail))

  loop_tests(replicate_List(Unit, 65536), [test])

def first_failure_message(test: Test) -> Option[String]:
  def loop_tests(steps: List[Unit], todo: List[Test]) -> Option[String]:
    loop steps:
      case []:
        Some("test traversal exceeded step budget")
      case [_, *tail_steps]:
        match todo:
          case []:
            None
          case [head, *tail]:
            match head:
              case Assertion(value, message):
                if value:
                  loop_tests(tail_steps, tail)
                else:
                  Some(message)
              case TestSuite(_, tests):
                loop_tests(tail_steps, tests.concat(tail))

  loop_tests(replicate_List(Unit, 65536), [test])

def first_failing_steps(values: LazyList[a], test_fn: a -> Test, steps: List[Unit]) -> Option[a]:
  loop steps:
    case []:
      None
    case [_, *tail]:
      match uncons_LazyList(values):
        case None:
          None
        case Some((head, rest)):
          value = get_Lazy(head)
          if test_fn(value).test_passes():
            first_failing_steps(get_Lazy(rest), test_fn, tail)
          else:
            Some(value)

def first_failing(values: LazyList[a], test_fn: a -> Test) -> Option[a]:
  first_failing_steps(values, test_fn, replicate_List(Unit, 4096))

def shrink_to_smallest_steps(steps: List[Unit], current: a, shrink: a -> LazyList[a], test_fn: a -> Test) -> a:
  loop steps:
    case []:
      current
    case [_, *tail]:
      match first_failing(shrink(current), test_fn):
        case None:
          current
        case Some(next):
          shrink_to_smallest_steps(tail, next, shrink, test_fn)

def shrink_to_smallest(start: a, shrink: a -> LazyList[a], test_fn: a -> Test) -> a:
  shrink_to_smallest_steps(replicate_List(Unit, 128), start, shrink, test_fn)

def first_failure_and_shrunk_samples(samples: List[a], gen: Gen[a], test_fn: a -> Test) -> Option[(a, a)]:
  loop samples:
    case []:
      None
    case [head, *tail]:
      test = test_fn(head)
      if test.test_passes():
        first_failure_and_shrunk_samples(tail, gen, test_fn)
      else:
        Some((head, shrink_to_smallest(head, gen.shrink_Gen(), test_fn)))

def first_failure_and_shrunk(gen: Gen[a], count: Int, seed: Int, test_fn: a -> Test) -> Option[(a, a)]:
  samples = run_Rand(sequence_Rand(replicate_List(gen.gen_Rand(), count)), seed)
  first_failure_and_shrunk_samples(samples, gen, test_fn)

def render_failure(name: String, show: a -> String, original: a, shrunk: a, message: Option[String]) -> String:
  base = "${name} failed (original=${show(original)}, shrunk=${show(shrunk)})"
  match message:
    case None:
      base
    case Some(extra):
      if length_String(extra).eq_Int(0):
        base
      else:
        "${base}: ${extra}"

def list_size_loop(list: List[a], acc: Int) -> Int:
  loop list:
    case []:
      acc
    case [_, *tail]:
      list_size_loop(tail, acc.add(1))

def list_size(list: List[a]) -> Int:
  list_size_loop(list, 0)

def min_Int(a: Int, b: Int) -> Int:
  match cmp_Int(a, b):
    case LT | EQ:
      a
    case GT:
      b

def abs_Int(i: Int) -> Int:
  if cmp_Int(i, 0) matches LT:
    0.sub(i)
  else:
    i

def sign_Int(i: Int) -> Int:
  if cmp_Int(i, 0) matches LT:
    -1
  elif i.eq_Int(0):
    0
  else:
    1

def filter_LazyList(list: LazyList[a], pred: a -> Bool) -> LazyList[a]:
  filter_native_LazyList(list, pred)

def filter_map_LazyList(list: LazyList[a], fn: a -> Option[b]) -> LazyList[b]:
  mapped = to_List_LazyList(list).foldl_List([], (acc, item) -> (
    match fn(item):
      case Some(value):
        [value, *acc]
      case None:
        acc
  )).reverse()
  from_List_LazyList(mapped)

def shrink_Int(i: Int) -> LazyList[Int]:
  if i.eq_Int(0):
    empty_LazyList
  else:
    half = i.div(2)
    one = sign_Int(i)
    if half.eq_Int(0):
      singleton_LazyList(0)
    elif half.eq_Int(one):
      from_List_LazyList([0, one])
    else:
      from_List_LazyList([0, half, one])

def shrink_non_negative(i: Int) -> LazyList[Int]:
  filter_LazyList(shrink_Int(i), v -> cmp_Int(v, 0) matches GT | EQ)

def shrink_positive(i: Int) -> LazyList[Int]:
  if cmp_Int(i, 1) matches LT | EQ:
    empty_LazyList
  else:
    positive = to_List_LazyList(filter_LazyList(shrink_Int(i), v -> cmp_Int(v, 0) matches GT))
    from_List_LazyList([1].concat(positive))

def shrink_List(shrink_item)(list: List[a]) -> LazyList[List[a]]:
  match list:
    case []:
      empty_LazyList
    case [head, *tail]:
      candidates = match first_LazyList(shrink_item(head)):
        case Some(h):
          [tail, [head], [h, *tail]]
        case None:
          [tail, [head]]
      from_List_LazyList(candidates)

def to_ascii_Char(i: Int) -> Char:
  match int_to_Char(i):
    case Some(c):
      c
    case None:
      .'a'

def shrink_Char(char: Char) -> LazyList[Char]:
  filter_map_LazyList(shrink_Int(char_to_Int(char)), int_to_Char)

def int_List_to_String_or_empty(list: List[Int]) -> String:
  match int_List_to_String(list):
    case Some(str):
      str
    case None:
      ""

def shrink_String(str: String) -> LazyList[String]:
  ints = string_to_Int_List(str)
  filter_map_LazyList(shrink_List(shrink_Int)(ints), int_List_to_String)

def shrink_Option(shrink_item)(value: Option[a]) -> LazyList[Option[a]]:
  match value:
    case None:
      empty_LazyList
    case Some(item):
      match first_LazyList(shrink_item(item)):
        case Some(next):
          from_List_LazyList([None, Some(next)])
        case None:
          singleton_LazyList(None)

def shrink_Tuple2(shrink_left, shrink_right)((left, right): (a, b)) -> LazyList[(a, b)]:
  left_candidates = match first_LazyList(shrink_left(left)):
    case Some(l):
      [(l, right)]
    case None:
      []
  right_candidates = match first_LazyList(shrink_right(right)):
    case Some(r):
      [(left, r)]
    case None:
      []
  from_List_LazyList(left_candidates.concat(right_candidates))

def shrink_Tuple3(shrink_a, shrink_b, shrink_c)((a0, b0, c0): (a, b, c)) -> LazyList[(a, b, c)]:
  as = match first_LazyList(shrink_a(a0)):
    case Some(a1):
      [(a1, b0, c0)]
    case None:
      []
  bs = match first_LazyList(shrink_b(b0)):
    case Some(b1):
      [(a0, b1, c0)]
    case None:
      []
  cs = match first_LazyList(shrink_c(c0)):
    case Some(c1):
      [(a0, b0, c1)]
    case None:
      []
  from_List_LazyList(as.concat(bs).concat(cs))

def shrink_Tuple4(shrink_a, shrink_b, shrink_c, shrink_d)((a0, b0, c0, d0): (a, b, c, d)) -> LazyList[(a, b, c, d)]:
  as = match first_LazyList(shrink_a(a0)):
    case Some(a1):
      [(a1, b0, c0, d0)]
    case None:
      []
  bs = match first_LazyList(shrink_b(b0)):
    case Some(b1):
      [(a0, b1, c0, d0)]
    case None:
      []
  cs = match first_LazyList(shrink_c(c0)):
    case Some(c1):
      [(a0, b0, c1, d0)]
    case None:
      []
  ds = match first_LazyList(shrink_d(d0)):
    case Some(d1):
      [(a0, b0, c0, d1)]
    case None:
      []
  from_List_LazyList(as.concat(bs).concat(cs).concat(ds))

unit_Gen: Gen[Unit] = const_Gen(Unit)

bool_Gen: Gen[Bool] = Gen(
  map_Rand(int_range(2), i -> i.eq_Int(1)),
  b -> singleton_LazyList(False) if b else empty_LazyList,
)

comparison_Gen: Gen[Comparison] = Gen(
  map_Rand(int_range(3), i -> (
    if i.eq_Int(0):
      LT
    elif i.eq_Int(1):
      EQ
    else:
      GT
  )),
  c -> from_List_LazyList(match c:
    case LT:
      []
    case EQ:
      [LT]
    case GT:
      [EQ, LT],
  ),
)

int32_max = shift_left_Int(1, 31)

int_Gen: Gen[Int] = Gen(
  one_of_Int(
    int8_signed_Range,
    [int16_signed_Range, int32_signed_Range, int64_signed_Range, int128_signed_Range],
  ),
  shrink_Int,
)

int32_Gen: Gen[Int] = Gen(sample_Int(int32_signed_Range), shrink_Int)

uint32_Gen: Gen[Int] = Gen(sample_Int(uint32_Range), shrink_non_negative)

pos_Int_Gen: Gen[Int] = Gen(
  one_of_Int(
    pos_int8_Range,
    [pos_int16_Range, pos_int32_Range],
  ),
  shrink_positive,
)

ascii_printable_Range = linear_Range(32, 127)
short_string_length_Range = linear_Range(0, 24)
short_list_length_Range = linear_Range(0, 16)

char_Gen: Gen[Char] = Gen(
  map_Rand(sample_Int(ascii_printable_Range), to_ascii_Char),
  shrink_Char,
)

string_Gen: Gen[String] = Gen(
  flat_map_Rand(sample_Int(short_string_length_Range), len -> (
    chars = replicate_List(char_Gen.gen_Rand(), len)
    map_Rand(sequence_Rand(chars), list -> (
      int_values = list.map_List(char_to_Int)
      int_List_to_String_or_empty(int_values)
    ))
  )),
  shrink_String,
)

float_zero = int_to_Float64(0)
float_one = int_to_Float64(1)
float_scale = int_to_Float64(1000000)

def signed_Float64(neg: Bool, value: Float64) -> Float64:
  if neg:
    subf(float_zero, value)
  else:
    value

rand_unit_float: Rand[Float64] = map_Rand(
  int_range(1000000),
  i -> divf(int_to_Float64(i), float_scale),
)

rand_signed_unit_float: Rand[Float64] = map_Rand(
  prod_Rand(bool_Gen.gen_Rand(), rand_unit_float),
  ((neg, value)) -> signed_Float64(neg, value),
)

rand_exp_float: Rand[Float64] = map_Rand(
  prod_Rand(bool_Gen.gen_Rand(), geometric_Int),
  ((neg, exp0)) -> (
    exp = min_Int(exp0, 60)
    mag = int_to_Float64(shift_left_Int(1, exp))
    signed_Float64(neg, mag)
  ),
)

def shrink_Float64(value: Float64) -> LazyList[Float64]:
  if cmp_Float64(value, float_zero) matches EQ:
    empty_LazyList
  else:
    half = divf(value, int_to_Float64(2))
    mirrored = subf(float_zero, half)
    if cmp_Float64(abs(value), float_one) matches LT:
      from_List_LazyList([float_zero, half])
    else:
      from_List_LazyList([float_zero, half, mirrored])

float64_Gen: Gen[Float64] = Gen(
  one_of(rand_unit_float, [rand_signed_unit_float, rand_exp_float]),
  shrink_Float64,
)

def option_Gen(gen: Gen[a]) -> Gen[Option[a]]:
  Gen(
    flat_map_Rand(sample_Int(linear_Range(0, 4)), i -> (
      if i.eq_Int(0):
        const_Rand(None)
      else:
        map_Rand(gen.gen_Rand(), Some)
    )),
    shrink_Option(gen.shrink_Gen()),
  )

def list_Gen(gen: Gen[a]) -> Gen[List[a]]:
  Gen(
    flat_map_Rand(sample_Int(short_list_length_Range), len -> sequence_Rand(replicate_List(gen.gen_Rand(), len))),
    shrink_List(gen.shrink_Gen()),
  )

def tuple2_Gen(left: Gen[a], right: Gen[b]) -> Gen[(a, b)]:
  Gen(
    prod_Rand(left.gen_Rand(), right.gen_Rand()),
    shrink_Tuple2(left.shrink_Gen(), right.shrink_Gen()),
  )

def tuple3_Gen(ga: Gen[a], gb: Gen[b], gc: Gen[c]) -> Gen[(a, b, c)]:
  Gen(
    map_Rand(prod_Rand(prod_Rand(ga.gen_Rand(), gb.gen_Rand()), gc.gen_Rand()), (((a0, b0), c0)) -> (a0, b0, c0)),
    shrink_Tuple3(ga.shrink_Gen(), gb.shrink_Gen(), gc.shrink_Gen()),
  )

def tuple4_Gen(ga: Gen[a], gb: Gen[b], gc: Gen[c], gd: Gen[d]) -> Gen[(a, b, c, d)]:
  Gen(
    map_Rand(
      prod_Rand(prod_Rand(prod_Rand(ga.gen_Rand(), gb.gen_Rand()), gc.gen_Rand()), gd.gen_Rand()),
      ((((a0, b0), c0), d0)) -> (a0, b0, c0, d0)
    ),
    shrink_Tuple4(ga.shrink_Gen(), gb.shrink_Gen(), gc.shrink_Gen(), gd.shrink_Gen()),
  )

struct Prop(run: Int -> Rand[Test])

def run_count(prop: Prop, count: Int) -> Rand[Test]:
  Prop(run) = prop
  run(count)

def forall_Prop(gen: Gen[a], name: String, show: a -> String, test_fn: a -> Test) -> Prop:
  Prop(count -> (
    samples_rand = sequence_Rand(replicate_List(gen.gen_Rand(), count))
    map_Rand(samples_rand, samples -> (
      match first_failure_and_shrunk_samples(samples, gen, test_fn):
        case None:
          Assertion(True, name)
        case Some((original, shrunk)):
          fail_message = first_failure_message(test_fn(shrunk))
          Assertion(False, render_failure(name, show, original, shrunk, fail_message))
    ))
  ))

def suite_Prop(name: String, props: List[Prop]) -> Prop:
  Prop(count -> (
    all_runs = [run_count(prop, count) for prop in props]
    map_Rand(sequence_Rand(all_runs), tests -> TestSuite(name, tests))
  ))

def run_Prop(prop: Prop, count: Int, seed: Int) -> Test:
  run_Rand(run_count(prop, count), seed)

def show_Bool(bool: Bool) -> String:
  if bool:
    "True"
  else:
    "False"

def show_Comparison(comp: Comparison) -> String:
  match comp:
    case LT:
      "LT"
    case EQ:
      "EQ"
    case GT:
      "GT"

def show_Char(c: Char) -> String:
  int_to_String(char_to_Int(c))

def show_Option_Int(opt: Option[Int]) -> String:
  match opt:
    case None:
      "None"
    case Some(i):
      "Some(${int_to_String(i)})"

def show_Int_List(list: List[Int]) -> String:
  "List(size=${int_to_String(list_size(list))})"

def always_valid_prop(gen: Gen[a], name: String, show: a -> String, fn: a -> Bool) -> Prop:
  forall_Prop(gen, name, show, a -> Assertion(fn(a), name))

predef_generators_prop: Prop = suite_Prop("Predef generators", [
  always_valid_prop(unit_Gen, "Unit", _ -> "Unit", _ -> True),
  always_valid_prop(bool_Gen, "Bool", show_Bool, b -> (
    expected_len = 4 if b else 5
    length_String(show_Bool(b)).eq_Int(expected_len)
  )),
  always_valid_prop(comparison_Gen, "Comparison", show_Comparison, c -> (
    idx = match c:
      case LT:
        -1
      case EQ:
        0
      case GT:
        1
    if c matches EQ:
      idx.eq_Int(0)
    else:
      abs_Int(idx).eq_Int(1)
  )),
  always_valid_prop(int_Gen, "Int reflexive", int_to_String, i -> i.eq_Int(i)),
  always_valid_prop(int32_Gen, "Int32-ish", int_to_String, i -> cmp_Int(abs_Int(i), int32_max) matches LT | EQ),
  always_valid_prop(uint32_Gen, "UInt32-ish", int_to_String, i -> cmp_Int(i, 0) matches GT | EQ),
  always_valid_prop(pos_Int_Gen, "Positive Int", int_to_String, i -> cmp_Int(i, 0) matches GT),
  always_valid_prop(char_Gen, "Char round-trip", show_Char, c -> int_to_Char(char_to_Int(c)) matches Some(_)),
  always_valid_prop(string_Gen, "String round-trip", s -> s, s -> int_List_to_String(string_to_Int_List(s)) matches Some(_)),
  always_valid_prop(float64_Gen, "Float64 finite", float64_to_String, is_finite),
  always_valid_prop(option_Gen(int_Gen), "Option[Int]", show_Option_Int, o -> (
    match o:
      case None:
        True
      case Some(i):
        i.eq_Int(i)
  )),
  always_valid_prop(list_Gen(int_Gen), "List[Int]", show_Int_List, list -> eq_List(eq_Int)(list.reverse().reverse(), list)),
  always_valid_prop(tuple2_Gen(int_Gen, bool_Gen), "Tuple2[Int, Bool]", _ -> "tuple2", ((i, b)) -> i.eq_Int(i) if b else i.eq_Int(i)),
  always_valid_prop(tuple3_Gen(int_Gen, bool_Gen, char_Gen), "Tuple3", _ -> "tuple3", ((i, _, c)) -> and_Bool(i.eq_Int(i), char_to_Int(c).eq_Int(char_to_Int(c)))),
  always_valid_prop(tuple4_Gen(int_Gen, bool_Gen, char_Gen, string_Gen), "Tuple4", _ -> "tuple4", ((i, _, c, s)) -> and_Bool(i.eq_Int(i), and_Bool(char_to_Int(c).eq_Int(char_to_Int(c)), int_List_to_String(string_to_Int_List(s)) matches Some(_)))),
])

non_one_int_Range = linear_Range(2, 1026)
non_empty_list_len_Range = linear_Range(1, 9)

def non_one_int_Gen() -> Gen[Int]:
  Gen(
    sample_Int(non_one_int_Range),
    shrink_positive,
  )

def non_empty_int_list_Gen() -> Gen[List[Int]]:
  Gen(
    flat_map_Rand(sample_Int(non_empty_list_len_Range), len -> (
      sequence_Rand(replicate_List(int_Gen.gen_Rand(), len))
    )),
    shrink_List(shrink_Int),
  )

def suite_recursion_witness() -> Test:
  nested = TestSuite("outer", [
    Assertion(True, "top passes"),
    TestSuite("inner", [Assertion(False, "inner fails")]),
  ])
  passes = not_Bool(nested.test_passes())
  has_message = nested.first_failure_message() matches Some("inner fails")
  Assertion(and_Bool(passes, has_message), "suite recursion should inspect child tests")

def shrink_int_witness() -> Test:
  match first_failure_and_shrunk(non_one_int_Gen(), 20, 99, i -> Assertion(i.add(i).eq_Int(i), "2*x == x")):
    case None:
      Assertion(False, "expected failing int sample")
    case Some((original, shrunk)):
      small = shrunk.eq_Int(1)
      not_already_small = cmp_Int(original, 1) matches GT
      Assertion(and_Bool(small, not_already_small), "int shrink should reach 1, got ${int_to_String(shrunk)} from ${int_to_String(original)}")

def shrink_list_witness() -> Test:
  match first_failure_and_shrunk(non_empty_int_list_Gen(), 20, 123, list -> Assertion(list matches [], "expected empty list")):
    case None:
      Assertion(False, "expected failing non-empty list sample")
    case Some((original, shrunk)):
      orig_sz = list_size(original)
      shrunk_sz = list_size(shrunk)
      Assertion(and_Bool(not_Bool(orig_sz.eq_Int(0)), shrunk_sz.eq_Int(1)), "list shrink should reach size 1, got size ${int_to_String(shrunk_sz)} from ${int_to_String(orig_sz)}")

