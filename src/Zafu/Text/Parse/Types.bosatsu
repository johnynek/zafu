def parse_prefix(parser: Parser0[a], text: String) -> Result[Error, (String, a)]:
  match parse0_with_state(parser, text):
    case Ok((final_state, value)):
      Ok((state_remaining(final_state), value))
    case Err(err):
      Err(err)

def parse_offset(parser: Parser0[a], text: String) -> Result[Error, (Int, a)]:
  match parse0_with_state(parser, text):
    case Ok((final_state, value)):
      Ok((state_char_offset(final_state), value))
    case Err(err):
      Err(err)

def parse(parser: Parser[a], text: String) -> Result[Error, a]:
  full_parser = product(parser, end)
  match parse1_with_state(full_parser, text):
    case Ok((_, pair)):
      (value, _) = pair
      Ok(value)
    case Err(err):
      Err(err)
