def soft_product0(left: Parser0[a], right: Parser0[b]) -> Parser0[(a, b)]:
  mk_parser0(
    state -> dispatch(state, spent_state -> (
      match run_parser0(left, spent_state):
        case Success(left_value, after_left):
          match run_parser0(right, after_left):
            case Success(right_value, after_right):
              Success((left_value, right_value), after_right)
            case Failure(right_failure):
              failure =
                # Soft product backtracks only when right fails without consumption.
                if failure_kind(right_failure) matches Arresting:
                  right_failure
                elif consumed_tokens(spent_state, after_left):
                  ParseFailure(Epsilon, failure_error(right_failure))
                else:
                  right_failure
              Failure(failure)
        case Failure(left_failure):
          Failure(left_failure)
    )),
    parser0_cost(left).add(parser0_cost(right)).add(1),
    and(parser0_allows_epsilon(left), parser0_allows_epsilon(right)),
  )

