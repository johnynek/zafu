def not_then(forbidden: Parser0[a], then_parse: Parser[b]) -> Parser[b]:
  mk_parser(
    state -> dispatch(state, spent_state -> (
      match run_parser0(forbidden, spent_state):
        case Success(_, _):
          Failure(epsilon_failure_at(spent_state, [ExpectedPredicate("not_then")]))
        case Failure(_):
          run_parser(then_parse, spent_state)
    )),
    parser0_cost(forbidden).add(parser_cost(then_parse)).add(2),
  )

def rep0(parser: Parser[a]) -> Parser0[List[a]]:
  mk_parser0(
    state -> dispatch(state, spent_state -> (
      def loop_rep(rem_steps: Int, curr_state: ParseState, rev_items: List[a]) -> Step[List[a]]:
        loop rem_steps:
          case _ if cmp_Int(rem_steps, 0) matches LT | EQ:
            # A secondary guard keeps this loop total even if a malformed parser violates invariants.
            Failure(fuel_failure(curr_state))
          case _:
            match run_parser(parser, curr_state):
              case Success(item, next_state):
                if consumed_tokens(curr_state, next_state):
                  loop_rep(rem_steps.sub(1), next_state, [item, *rev_items])
                else:
                  Failure(epsilon_failure_at(next_state, [FailWith("rep0 invariant violation: item parser did not consume input")]))
              case Failure(failure):
                if failure_kind(failure) matches Arresting:
                  Failure(failure)
                else:
                  Success(rev_items.reverse(), curr_state)
      loop_rep(state_fuel(spent_state), spent_state, [])
    )),
    parser_cost(parser).add(1),
    True,
  )

def rep(parser: Parser[a]) -> Parser[NonEmpty[a]]:
  map(product10(parser, rep0(parser)), pair -> (
    (head, tail) = pair
    from_prepend_NonEmptyList(head, tail)
  ))

def rep_exactly(parser: Parser[a], times: Int) -> Parser[NonEmpty[a]]:
  if cmp_Int(times, 1) matches LT:
    fail_with("rep_exactly requires times >= 1")
  else:
    mk_parser(
      state -> dispatch(state, spent_state -> (
        match run_parser(parser, spent_state):
          case Success(head, first_state):
            if consumed_tokens(spent_state, first_state):
              def loop_exact(
                curr_state: ParseState,
                rem_times: Int,
                rev_tail: List[a],
              ) -> Step[NonEmpty[a]]:
                loop rem_times:
                  case _ if cmp_Int(rem_times, 0) matches LT | EQ:
                    Success(from_prepend_NonEmptyList(head, rev_tail.reverse()), curr_state)
                  case _:
                    match run_parser(parser, curr_state):
                      case Success(item, next_state):
                        if consumed_tokens(curr_state, next_state):
                          loop_exact(next_state, rem_times.sub(1), [item, *rev_tail])
                        else:
                          Failure(epsilon_failure_at(next_state, [FailWith("rep_exactly invariant violation: item parser did not consume input")]))
                      case Failure(failure):
                        Failure(mark_arresting(failure))
              loop_exact(first_state, times.sub(1), [])
            else:
              Failure(epsilon_failure_at(first_state, [FailWith("rep_exactly invariant violation: item parser did not consume input")]))
          case Failure(failure):
            Failure(failure)
      )),
      parser_cost(parser).mul(times).add(1),
    )

def rep0_max(parser: Parser[a], max_items: Int) -> Parser0[List[a]]:
  if cmp_Int(max_items, 0) matches LT | EQ:
    pure0([])
  else:
    mk_parser0(
      state -> dispatch(state, spent_state -> (
        def loop_rep(curr_state: ParseState, rem_max: Int, rev_items: List[a]) -> Step[List[a]]:
          loop rem_max:
            case _ if cmp_Int(rem_max, 0) matches LT | EQ:
              Success(rev_items.reverse(), curr_state)
            case _:
              match run_parser(parser, curr_state):
                case Success(item, next_state):
                  if consumed_tokens(curr_state, next_state):
                    loop_rep(next_state, rem_max.sub(1), [item, *rev_items])
                  else:
                    Failure(epsilon_failure_at(next_state, [FailWith("rep0_max invariant violation: item parser did not consume input")]))
                case Failure(failure):
                  if failure_kind(failure) matches Arresting:
                    Failure(failure)
                  else:
                    Success(rev_items.reverse(), curr_state)
        loop_rep(spent_state, max_items, [])
      )),
      parser_cost(parser).add(1),
      True,
    )

def rep_min(parser: Parser[a], min_items: Int) -> Parser[NonEmpty[a]]:
  normalized_min =
    if cmp_Int(min_items, 1) matches LT:
      1
    else:
      min_items
  if normalized_min.eq_Int(1):
    rep(parser)
  else:
    map(product10(rep_exactly(parser, normalized_min), rep0(parser)), pair -> (
      (required_items, extra_items) = pair
      from_prepend_NonEmptyList(
        head_NonEmptyList(required_items),
        [*tail_NonEmptyList(required_items), *extra_items],
      )
    ))

def rep_min_max(parser: Parser[a], min_items: Int, max_items: Int) -> Parser[NonEmpty[a]]:
  normalized_min =
    if cmp_Int(min_items, 1) matches LT:
      1
    else:
      min_items
  if cmp_Int(max_items, normalized_min) matches LT:
    fail_with("rep_min_max requires max >= min and min >= 1")
  else:
    map(product10(rep_exactly(parser, normalized_min), rep0_max(parser, max_items.sub(normalized_min))), pair -> (
      (required_items, extra_items) = pair
      from_prepend_NonEmptyList(
        head_NonEmptyList(required_items),
        [*tail_NonEmptyList(required_items), *extra_items],
      )
    ))

def tail_value(pair: (a, b)) -> b:
  (_, right) = pair
  right

def rep_sep(parser: Parser[a], sep: Parser0[s]) -> Parser[NonEmpty[a]]:
  tail_parser = map(product01(sep, parser), tail_value)
  map(product10(parser, rep0(tail_parser)), pair -> (
    (head, tail) = pair
    from_prepend_NonEmptyList(head, tail)
  ))

def rep_sep0(parser: Parser[a], sep: Parser0[s]) -> Parser0[List[a]]:
  map0(optional(rep_sep(parser, sep)), maybe_items -> (
    match maybe_items:
      case Some(items):
        to_List_NonEmptyList(items)
      case None:
        []
  ))

def rep_until0(parser: Parser[a], end_parser: Parser0[e]) -> Parser0[List[a]]:
  mk_parser0(
    state -> dispatch(state, spent_state -> (
      def loop_until(rem_steps: Int, curr_state: ParseState, rev_items: List[a]) -> Step[List[a]]:
        loop rem_steps:
          case _ if cmp_Int(rem_steps, 0) matches LT | EQ:
            Failure(fuel_failure(curr_state))
          case _:
            # End parser is checked first so terminators are not consumed as items.
            match run_parser0(end_parser, curr_state):
              case Success(_, after_end):
                Success(rev_items.reverse(), after_end)
              case Failure(end_failure):
                if failure_kind(end_failure) matches Arresting:
                  Failure(end_failure)
                else:
                  match run_parser(parser, curr_state):
                    case Success(item, next_state):
                      if consumed_tokens(curr_state, next_state):
                        loop_until(rem_steps.sub(1), next_state, [item, *rev_items])
                      else:
                        Failure(epsilon_failure_at(next_state, [FailWith("rep_until0 invariant violation: item parser did not consume input")]))
                    case Failure(item_failure):
                      if failure_kind(item_failure) matches Arresting:
                        Failure(item_failure)
                      else:
                        Failure(merge_failures(end_failure, item_failure))
      loop_until(state_fuel(spent_state), spent_state, [])
    )),
    parser_cost(parser).add(parser0_cost(end_parser)).add(1),
    True,
  )

def rep_until(parser: Parser[a], end_parser: Parser0[e]) -> Parser[List[a]]:
  map(product10(parser, rep_until0(parser, end_parser)), pair -> (
    (head, tail) = pair
    [head, *tail]
  ))

def chain_left1(term: Parser[a], op: Parser[(a, a) -> a]) -> Parser[a]:
  pair_parser = product(op, term)
  tail_parser = rep0(pair_parser)
  map(product10(term, tail_parser), pair -> (
    (first, pairs) = pair
    pairs.foldl_List(first, (acc, next_pair) -> (
      (fn, rhs) = next_pair
      fn(acc, rhs)
    ))
  ))

def chain_right1(term: Parser[a], op: Parser[(a, a) -> a]) -> Parser[a]:
  pair_parser = product(op, term)
  tail_parser = rep0(pair_parser)
  map(product10(term, tail_parser), pair -> (
    (first, pairs) = pair
    match pairs:
      case []:
        first
      case _:
        (ops_rev, terms_rev) = pairs.foldl_List(([], [first]), (acc, next_pair) -> (
          (ops_acc, terms_acc) = acc
          (next_op, next_term) = next_pair
          ([next_op, *ops_acc], [next_term, *terms_acc])
        ))
        match terms_rev:
          case [last_term, *rest_terms_rev]:
            def reduce_loop(rem_ops: List[(a, a) -> a], rem_terms: List[a], acc_value: a) -> a:
              loop rem_ops:
                case []:
                  acc_value
                case [next_op, *tail_ops]:
                  match rem_terms:
                    case [next_term, *tail_terms]:
                      reduce_loop(tail_ops, tail_terms, next_op(next_term, acc_value))
                    case []:
                      acc_value
            reduce_loop(ops_rev, rest_terms_rev, last_term)
          case []:
            first
  ))

