from Zafu/Cli/Args/Internal/Core import (
  Parsed,
  RequestedHelp,
  RequestedVersion,
  Failed,
)

export (
  main,
)

enum Json:
  JNull
  JBool(value: Bool)
  JNumber(raw: String)
  JString(raw_content: String)
  JArray(items: List[Json])
  JObject(fields: List[(String, Json)])

enum OutputStyle:
  Compact
  Pretty(indent_size: Int)

read_chunk_size = 4096

double_quote_char: Char = .'\"'
backslash_char: Char = .'\\'
minus_char: Char = .'-'
plus_char: Char = .'+'
dot_char: Char = .'.'
comma_char: Char = .','
colon_char: Char = .':'
open_brace_char: Char = .'{'
close_brace_char: Char = .'}'
open_bracket_char: Char = .'['
close_bracket_char: Char = .']'
zero_char: Char = .'0'
e_char: Char = .'e'
upper_e_char: Char = .'E'
u_char: Char = .'u'

simple_escape_chars = string_to_Char_List("\"\\/bfnrt")

def is_json_space(ch: Char) -> Bool:
  ch matches .' ' | .'\t' | .'\n' | .'\r'

json_space_char = char_where(is_json_space, "JSON whitespace")

def token(parser):
  ws = map0(rep0(json_space_char), _ -> Unit)
  keep_right(ws, keep_left(parser, ws))

def nonempty_chars_to_String(chars) -> String:
  char_List_to_String(to_List_NonEmptyList(chars))

def is_unescaped_string_char(ch: Char) -> Bool:
  if ch matches .'\"':
    False
  elif ch matches .'\\':
    False
  else:
    cmp_Int(char_to_Int(ch), 32) matches GT | EQ

unescaped_string_chunk: Parser[String] = (
  chars = rep(char_where(is_unescaped_string_char, "JSON string character"))
  map(chars, nonempty_chars_to_String)
)

hex_digit_char = char_where(is_ascii_hex, "hex digit")

simple_escape_chunk: Parser[String] = (
  map(product(char(backslash_char), char_in(simple_escape_chars)), ((_, escaped_char)) -> (
    concat_String(["\\", char_to_String(escaped_char)])
  ))
)

unicode_escape_chunk: Parser[String] = (
  map(
    product(
      product(char(backslash_char), char(u_char)),
      product(
        product(hex_digit_char, hex_digit_char),
        product(hex_digit_char, hex_digit_char),
      ),
    ),
    ((_, ((h1, h2), (h3, h4)))) -> (
      concat_String([
        "\\u",
        char_to_String(h1),
        char_to_String(h2),
        char_to_String(h3),
        char_to_String(h4),
      ])
    ),
  )
)

json_string_content_parser: Parser[String] = (
  piece_parser = one_of([
    unicode_escape_chunk,
    simple_escape_chunk,
    unescaped_string_chunk,
  ])
  map(
    product(
      product10(char(double_quote_char), rep0(piece_parser)),
      char(double_quote_char),
    ),
    ((((_, pieces), _))) -> (
      concat_String(pieces)
    ),
  )
)

def is_nonzero_digit(ch: Char) -> Bool:
  code = char_to_Int(ch)
  and(cmp_Int(code, 48) matches GT, cmp_Int(code, 57) matches LT | EQ)

digit_char = char_where(is_ascii_digit, "digit")
nonzero_digit_char = char_where(is_nonzero_digit, "non-zero digit")

def digits_to_String(head: Char, tail: List[Char]) -> String:
  char_List_to_String([head, *tail])

number_integer_part: Parser[String] = (
  one_of([
    map(char(zero_char), _ -> "0"),
    map(product10(nonzero_digit_char, rep0(digit_char)), ((head, tail)) -> (
      digits_to_String(head, tail)
    )),
  ])
)

number_fraction_part: Parser[String] = (
  map(product(char(dot_char), rep(digit_char)), ((_, digits)) -> (
    concat_String([".", nonempty_chars_to_String(digits)])
  ))
)

number_exp_sign0: Parser0[String] = (
  map0(optional(char_in([plus_char, minus_char])), maybe_sign -> (
    match maybe_sign:
      case Some(sign_char):
        char_to_String(sign_char)
      case None:
        ""
  ))
)

number_exp_part: Parser[String] = (
  map(product(char_in([e_char, upper_e_char]), product01(number_exp_sign0, rep(digit_char))), ((exp_mark, (sign_part, digits))) -> (
    concat_String([
      char_to_String(exp_mark),
      sign_part,
      nonempty_chars_to_String(digits),
    ])
  ))
)

number_fraction0: Parser0[String] = (
  map0(optional(number_fraction_part), maybe_fraction -> (
    match maybe_fraction:
      case Some(fraction):
        fraction
      case None:
        ""
  ))
)

number_exp0: Parser0[String] = (
  map0(optional(number_exp_part), maybe_exp -> (
    match maybe_exp:
      case Some(exp_part):
        exp_part
      case None:
        ""
  ))
)

number_sign0: Parser0[String] = (
  map0(optional(char(minus_char)), maybe_minus -> (
    match maybe_minus:
      case Some(_):
        "-"
      case None:
        ""
  ))
)

json_number_parser: Parser[Json] = (
  core = map(product10(number_integer_part, product0(number_fraction0, number_exp0)), ((int_part, (fraction_part, exp_part))) -> (
    concat_String([int_part, fraction_part, exp_part])
  ))

  label(
    map(product01(number_sign0, core), ((sign_part, rest_part)) -> (
      JNumber(concat_String([sign_part, rest_part]))
    )),
    "JSON number",
  )
)

json_true_parser = map(string("true"), _ -> JBool(True))
json_false_parser = map(string("false"), _ -> JBool(False))
json_null_parser = map(string("null"), _ -> JNull)

scalar_json_parser: Parser[Json] = (
  one_of([
    json_null_parser,
    json_true_parser,
    json_false_parser,
    json_number_parser,
    map(json_string_content_parser, content -> JString(content)),
  ])
)

enum JsonToken:
  TokOpenObj
  TokCloseObj
  TokOpenArr
  TokCloseArr
  TokColon
  TokComma
  TokScalar(value: Json)

json_token_parser: Parser[JsonToken] = (
  one_of([
    map(char(open_brace_char), _ -> TokOpenObj),
    map(char(close_brace_char), _ -> TokCloseObj),
    map(char(open_bracket_char), _ -> TokOpenArr),
    map(char(close_bracket_char), _ -> TokCloseArr),
    map(char(colon_char), _ -> TokColon),
    map(char(comma_char), _ -> TokComma),
    map(scalar_json_parser, value -> TokScalar(value)),
  ])
)

json_tokens_parser: Parser[List[JsonToken]] = (
  tok = token(label(json_token_parser, "JSON token"))
  map(product10(tok, rep0(tok)), ((head, tail)) -> [head, *tail])
)

enum BuildFrame:
  ArrExpectFirstOrClose(items_rev: List[Json])
  ArrExpectValueAfterComma(items_rev: List[Json])
  ArrExpectCommaOrClose(items_rev: List[Json])
  ObjExpectFirstKeyOrClose(fields_rev: List[(String, Json)])
  ObjExpectKeyAfterComma(fields_rev: List[(String, Json)])
  ObjExpectColon(fields_rev: List[(String, Json)], key: String)
  ObjExpectValue(fields_rev: List[(String, Json)], key: String)
  ObjExpectCommaOrClose(fields_rev: List[(String, Json)])

def accept_value(
  value: Json,
  stack: List[BuildFrame],
  root: Option[Json],
) -> Result[String, (List[BuildFrame], Option[Json])]:
  match stack:
    case []:
      match root:
        case Some(_):
          Err("multiple top-level JSON values")
        case None:
          Ok(([], Some(value)))
    case [ArrExpectFirstOrClose(items_rev), *tail]:
      Ok(([ArrExpectCommaOrClose([value, *items_rev]), *tail], root))
    case [ArrExpectValueAfterComma(items_rev), *tail]:
      Ok(([ArrExpectCommaOrClose([value, *items_rev]), *tail], root))
    case [ObjExpectValue(fields_rev, key), *tail]:
      Ok(([ObjExpectCommaOrClose([(key, value), *fields_rev]), *tail], root))
    case _:
      Err("unexpected JSON value")

def begin_container(
  frame: BuildFrame,
  stack: List[BuildFrame],
  root: Option[Json],
) -> Result[String, (List[BuildFrame], Option[Json])]:
  match stack:
    case []:
      match root:
        case Some(_):
          Err("multiple top-level JSON values")
        case None:
          Ok(([frame], root))
    case [ArrExpectFirstOrClose(items_rev), *tail]:
      Ok(([frame, ArrExpectFirstOrClose(items_rev), *tail], root))
    case [ArrExpectValueAfterComma(items_rev), *tail]:
      Ok(([frame, ArrExpectValueAfterComma(items_rev), *tail], root))
    case [ObjExpectValue(fields_rev, key), *tail]:
      Ok(([frame, ObjExpectValue(fields_rev, key), *tail], root))
    case _:
      Err("unexpected JSON container start")

def parse_json_tokens(tokens: List[JsonToken]) -> Result[String, Json]:
  def loop(rem: List[JsonToken], stack: List[BuildFrame], root: Option[Json]) -> Result[String, Json]:
    loop (rem, stack):
      case ([], []):
        match root:
          case Some(value):
            Ok(value)
          case None:
            Err("empty JSON input")
      case ([], _):
        Err("unexpected end of JSON input")
      case ([TokOpenArr, *tail], current_stack):
        match begin_container(ArrExpectFirstOrClose([]), current_stack, root):
          case Ok((next_stack, next_root)):
            loop(tail, next_stack, next_root)
          case Err(msg):
            Err(msg)
      case ([TokOpenObj, *tail], current_stack):
        match begin_container(ObjExpectFirstKeyOrClose([]), current_stack, root):
          case Ok((next_stack, next_root)):
            loop(tail, next_stack, next_root)
          case Err(msg):
            Err(msg)
      case ([TokScalar(JString(key)), *tail], [ObjExpectFirstKeyOrClose(fields_rev), *tail_stack]):
        loop(tail, [ObjExpectColon(fields_rev, key), *tail_stack], root)
      case ([TokScalar(_), *_], [ObjExpectFirstKeyOrClose(_), *_]):
        Err("JSON object keys must be strings")
      case ([TokScalar(JString(key)), *tail], [ObjExpectKeyAfterComma(fields_rev), *tail_stack]):
        loop(tail, [ObjExpectColon(fields_rev, key), *tail_stack], root)
      case ([TokScalar(_), *_], [ObjExpectKeyAfterComma(_), *_]):
        Err("JSON object keys must be strings")
      case ([TokScalar(value), *tail], current_stack):
        match accept_value(value, current_stack, root):
          case Ok((next_stack, next_root)):
            loop(tail, next_stack, next_root)
          case Err(msg):
            Err(msg)
      case ([TokColon, *tail], [ObjExpectColon(fields_rev, key), *tail_stack]):
        loop(tail, [ObjExpectValue(fields_rev, key), *tail_stack], root)
      case ([TokColon, *_], _):
        Err("unexpected ':' in JSON input")
      case ([TokComma, *tail], [ArrExpectCommaOrClose(items_rev), *tail_stack]):
        loop(tail, [ArrExpectValueAfterComma(items_rev), *tail_stack], root)
      case ([TokComma, *tail], [ObjExpectCommaOrClose(fields_rev), *tail_stack]):
        loop(tail, [ObjExpectKeyAfterComma(fields_rev), *tail_stack], root)
      case ([TokComma, *_], _):
        Err("unexpected ',' in JSON input")
      case ([TokCloseArr, *tail], [ArrExpectFirstOrClose(items_rev), *tail_stack]):
        match accept_value(JArray(items_rev.reverse()), tail_stack, root):
          case Ok((next_stack, next_root)):
            loop(tail, next_stack, next_root)
          case Err(msg):
            Err(msg)
      case ([TokCloseArr, *tail], [ArrExpectCommaOrClose(items_rev), *tail_stack]):
        match accept_value(JArray(items_rev.reverse()), tail_stack, root):
          case Ok((next_stack, next_root)):
            loop(tail, next_stack, next_root)
          case Err(msg):
            Err(msg)
      case ([TokCloseArr, *_], [ArrExpectValueAfterComma(_), *_]):
        Err("array cannot end right after ','")
      case ([TokCloseArr, *_], _):
        Err("unexpected ']' in JSON input")
      case ([TokCloseObj, *tail], [ObjExpectFirstKeyOrClose(fields_rev), *tail_stack]):
        match accept_value(JObject(fields_rev.reverse()), tail_stack, root):
          case Ok((next_stack, next_root)):
            loop(tail, next_stack, next_root)
          case Err(msg):
            Err(msg)
      case ([TokCloseObj, *tail], [ObjExpectCommaOrClose(fields_rev), *tail_stack]):
        match accept_value(JObject(fields_rev.reverse()), tail_stack, root):
          case Ok((next_stack, next_root)):
            loop(tail, next_stack, next_root)
          case Err(msg):
            Err(msg)
      case ([TokCloseObj, *_], [ObjExpectKeyAfterComma(_), *_]):
        Err("object cannot end right after ','")
      case ([TokCloseObj, *_], [ObjExpectColon(_, _), *_]):
        Err("expected ':' before '}'")
      case ([TokCloseObj, *_], [ObjExpectValue(_, _), *_]):
        Err("expected object value before '}'")
      case ([TokCloseObj, *_], _):
        Err("unexpected '}' in JSON input")

  loop(tokens, [], None)

def parse_json_input(input: String) -> Result[String, Json]:
  match parse(json_tokens_parser, input):
    case Ok(tokens):
      parse_json_tokens(tokens)
    case Err(parse_err):
      Error(_, failed_at, _, _) = parse_err
      Err("JSON parse failed at character offset ${int_to_String(failed_at)}")

def json_string_doc(content: String) -> Doc:
  text(concat_String(["\"", content, "\""]))

def indent_doc(level: Int, indent_size: Int) -> Doc:
  spaces(level.mul(indent_size))

enum RenderFrame:
  EmitDoc(doc: Doc)
  EmitValue(value: Json, level: Int)

def push_compact_values(items: List[Json], level: Int, tail: List[RenderFrame]) -> List[RenderFrame]:
  match items.reverse():
    case []:
      tail
    case [last, *rest_rev]:
      def loop(rem_rev: List[Json], acc: List[RenderFrame]) -> List[RenderFrame]:
        loop rem_rev:
          case []:
            acc
          case [next, *tail_rev]:
            loop(tail_rev, [EmitValue(next, level), EmitDoc(comma), *acc])

      loop(rest_rev, [EmitValue(last, level), *tail])

def push_pretty_values(
  items: List[Json],
  level: Int,
  indent_size: Int,
  tail: List[RenderFrame],
) -> List[RenderFrame]:
  indent = indent_doc(level, indent_size)
  sep = append(comma, hard_line)
  match items.reverse():
    case []:
      tail
    case [last, *rest_rev]:
      def loop(rem_rev: List[Json], acc: List[RenderFrame]) -> List[RenderFrame]:
        loop rem_rev:
          case []:
            acc
          case [next, *tail_rev]:
            loop(tail_rev, [EmitDoc(indent), EmitValue(next, level), EmitDoc(sep), *acc])

      loop(rest_rev, [EmitDoc(indent), EmitValue(last, level), *tail])

def push_compact_fields(fields: List[(String, Json)], level: Int, tail: List[RenderFrame]) -> List[RenderFrame]:
  match fields.reverse():
    case []:
      tail
    case [(last_key, last_value), *rest_rev]:
      seeded = [
        EmitDoc(json_string_doc(last_key)),
        EmitDoc(text(":")),
        EmitValue(last_value, level),
        *tail,
      ]
      def loop(rem_rev: List[(String, Json)], acc: List[RenderFrame]) -> List[RenderFrame]:
        loop rem_rev:
          case []:
            acc
          case [(next_key, next_value), *tail_rev]:
            loop(
              tail_rev,
              [
                EmitDoc(json_string_doc(next_key)),
                EmitDoc(text(":")),
                EmitValue(next_value, level),
                EmitDoc(comma),
                *acc,
              ],
            )

      loop(rest_rev, seeded)

def push_pretty_fields(
  fields: List[(String, Json)],
  level: Int,
  indent_size: Int,
  tail: List[RenderFrame],
) -> List[RenderFrame]:
  indent = indent_doc(level, indent_size)
  sep = append(comma, hard_line)
  match fields.reverse():
    case []:
      tail
    case [(last_key, last_value), *rest_rev]:
      seeded = [
        EmitDoc(indent),
        EmitDoc(json_string_doc(last_key)),
        EmitDoc(text(": ")),
        EmitValue(last_value, level),
        *tail,
      ]
      def loop(rem_rev: List[(String, Json)], acc: List[RenderFrame]) -> List[RenderFrame]:
        loop rem_rev:
          case []:
            acc
          case [(next_key, next_value), *tail_rev]:
            loop(
              tail_rev,
              [
                EmitDoc(indent),
                EmitDoc(json_string_doc(next_key)),
                EmitDoc(text(": ")),
                EmitValue(next_value, level),
                EmitDoc(sep),
                *acc,
              ],
            )

      loop(rest_rev, seeded)

def expand_array(
  items: List[Json],
  level: Int,
  style: OutputStyle,
  tail: List[RenderFrame],
) -> List[RenderFrame]:
  match style:
    case Compact:
      after_items = push_compact_values(items, level, [EmitDoc(text("]")), *tail])
      [EmitDoc(text("[")), *after_items]
    case Pretty(indent_size):
      match items:
        case []:
          [EmitDoc(text("[]")), *tail]
        case _:
          closing = [
            EmitDoc(hard_line),
            EmitDoc(indent_doc(level, indent_size)),
            EmitDoc(text("]")),
            *tail,
          ]
          after_items = push_pretty_values(items, level.add(1), indent_size, closing)
          [EmitDoc(text("[")), EmitDoc(hard_line), *after_items]

def expand_object(
  fields: List[(String, Json)],
  level: Int,
  style: OutputStyle,
  tail: List[RenderFrame],
) -> List[RenderFrame]:
  match style:
    case Compact:
      after_fields = push_compact_fields(fields, level, [EmitDoc(text("}")), *tail])
      [EmitDoc(text("{")), *after_fields]
    case Pretty(indent_size):
      match fields:
        case []:
          [EmitDoc(text("{}")), *tail]
        case _:
          closing = [
            EmitDoc(hard_line),
            EmitDoc(indent_doc(level, indent_size)),
            EmitDoc(text("}")),
            *tail,
          ]
          after_fields = push_pretty_fields(fields, level.add(1), indent_size, closing)
          [EmitDoc(text("{")), EmitDoc(hard_line), *after_fields]

def json_doc(value: Json, style: OutputStyle) -> Doc:
  def drain_non_container(stack: List[RenderFrame], rev_docs: List[Doc]) -> (List[RenderFrame], List[Doc]):
    def loop(stack: List[RenderFrame], rev_docs: List[Doc]) -> (List[RenderFrame], List[Doc]):
      loop stack:
        case [EmitDoc(doc), *tail]:
          loop(tail, [doc, *rev_docs])
        case [EmitValue(JNull, _), *tail]:
          loop(tail, [text("null"), *rev_docs])
        case [EmitValue(JBool(bool_value), _), *tail]:
          loop(tail, [text("true" if bool_value else "false"), *rev_docs])
        case [EmitValue(JNumber(raw_value), _), *tail]:
          loop(tail, [text(raw_value), *rev_docs])
        case [EmitValue(JString(content), _), *tail]:
          loop(tail, [json_string_doc(content), *rev_docs])
        case _:
          (stack, rev_docs)

    loop(stack, rev_docs)

  def loop(fuel: Int, stack: List[RenderFrame], rev_docs: List[Doc]) -> List[Doc]:
    loop (fuel, stack):
      case (_, []):
        rev_docs
      case _:
        (next_stack, next_rev_docs) = drain_non_container(stack, rev_docs)
        match next_stack:
          case []:
            next_rev_docs
          case [EmitValue(JArray(items), level), *tail] if cmp_Int(fuel, 0) matches GT:
            loop(fuel.sub(1), expand_array(items, level, style, tail), next_rev_docs)
          case [EmitValue(JObject(fields), level), *tail] if cmp_Int(fuel, 0) matches GT:
            loop(fuel.sub(1), expand_object(fields, level, style, tail), next_rev_docs)
          case _:
            [text("<render fuel exhausted>"), *next_rev_docs]

  docs = loop(2000000, [EmitValue(value, 0)], []).reverse()
  docs.foldl_List(empty, append)

def render_json(value: Json, style: OutputStyle) -> String:
  render(json_doc(value, style), 120)

style_args = (
  compact_flag = with_help(
    flag_value(from_prepend_NonEmptyList(long("compact"), []), Compact, arg_info),
    text("render compact JSON"),
  )
  spaces2_flag = with_help(
    flag_value(from_prepend_NonEmptyList(long("spaces2"), []), Pretty(2), arg_info),
    text("indent with two spaces"),
  )
  spaces4_flag = with_help(
    flag_value(from_prepend_NonEmptyList(long("spaces4"), []), Pretty(4), arg_info),
    text("indent with four spaces"),
  )
  with_default(
    or_else(or_else(compact_flag, spaces2_flag), spaces4_flag),
    Pretty(2),
    text("--spaces2"),
  )
)

json_format_command = with_help_flag(cli_command("json-format", style_args))

# `Main` may hand us argv with the command name first; keep it only when the
# leading token already looks like an option so direct invocations still work.
def normalize_cli_args(args: List[String]) -> List[String]:
  match args:
    case [head, *tail]:
      match string_to_Char_List(head):
        case [.'-', *_] | [.'/', *_]:
          args
        case _:
          tail
    case []:
      []

def read_stdin_all() -> Prog[IOError, Result[String, String]]:
  bytes <- read_all_bytes(stdin, read_chunk_size).await()
  match utf8_bytes_to_String(bytes):
    case Some(input):
      pure(Ok(input))
    case None:
      pure(Err("stdin is not valid UTF-8"))

def run(args: List[String]) -> Prog[IOError, Int]:
  cli_args = normalize_cli_args(args)
  match parse_cli(default_parse_config, json_format_command, cli_args):
    case Failed(_, doc):
      _ <- write_utf8(stderr, "${render(doc, 80)}\n").await()
      pure(2)
    case RequestedHelp(_, doc):
      _ <- write_utf8(stdout, "${render(doc, 80)}\n").await()
      pure(0)
    case RequestedVersion(doc):
      _ <- write_utf8(stdout, "${render(doc, 80)}\n").await()
      pure(0)
    case Parsed(style):
      input_result <- read_stdin_all().await()
      match input_result:
        case Ok(input):
          match parse_json_input(input):
            case Ok(value):
              rendered = render_json(value, style)
              _ <- write_utf8(stdout, "${rendered}\n").await()
              pure(0)
            case Err(parse_err):
              _ <- write_utf8(stderr, "${parse_err}\n").await()
              pure(1)
        case Err(input_err):
          _ <- write_utf8(stderr, "${input_err}\n").await()
          pure(1)

main: Main = Main(args -> (
  recover(run(args), err -> (
    io_err = "json formatter failed: ${error_to_String(err)}"
    _ <- recover(write_utf8(stderr, "${io_err}\n"), _ -> pure(Unit)).await()
    pure(1)
  ))
))
