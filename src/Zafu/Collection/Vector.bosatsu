exposes (
  Zafu/Abstract/Eq,
  Zafu/Abstract/Foldable,
  Zafu/Abstract/Hash,
  Zafu/Abstract/Monoid,
  Zafu/Abstract/Ord,
  Zafu/Abstract/Semigroup,
  Zafu/Abstract/Traverse,
